generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/.prisma/client"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  avatar    String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // === PRIVACY-PRESERVING VERIFICATION ===
  // NO PII stored per CYPHERPUNK-ARCHITECTURE.md
  // Address verified once via TEE, cached as session credential, then destroyed
  // District stored as hash only (not plaintext)

  // === VERIFICATION FIELDS ===
  is_verified         Boolean   @default(false) @map("is_verified")
  verification_method String?   @map("verification_method")
  verified_at         DateTime? @map("verified_at")

  // === SYBIL RESISTANCE FIELDS (Phase 1A Identity Verification) ===
  // Privacy-preserving identity verification for duplicate detection
  // See docs/adr/007-identity-schema-migration.md for design rationale
  identity_hash        String? @unique @map("identity_hash") // SHA-256(passport+nationality+birthYear+salt) - Sybil resistance
  identity_fingerprint String? @map("identity_fingerprint") // First 16 chars of hash for audit-safe logging
  birth_year           Int?    @map("birth_year") // Year only for 18+ age verification (NOT full DOB)

  // === CROSS-PROVIDER IDENTITY DEDUPLICATION (ISSUE-001) ===
  // Cryptographic identity commitment from self.xyz/Didit.me verification
  // Used to link multiple OAuth providers to the same verified person
  // When a verified user logs in with a new OAuth provider, accounts are merged
  identity_commitment String? @unique @map("identity_commitment")

  // === DOCUMENT TYPE (Wave 14R: authority level differentiation) ===
  // Stored at verification time to differentiate passport (L4) from ID card/license (L3)
  document_type String? @map("document_type") // 'passport' | 'drivers_license' | 'national_id'

  // === USER SECRET DERIVATION (Wave 14b: G-02 Sybil closure) ===
  // Random 32-byte entropy generated once at verification, stored AES-256-GCM encrypted
  // user_secret = Poseidon2(identity_commitment, user_entropy) — derived on-demand, never stored
  encrypted_entropy String? @map("encrypted_entropy") // AES-256-GCM(user_entropy, ENV key)

  // === AUTHORITY LEVEL (Wave 14c: G-03 authority enforcement) ===
  // Derived from verification method + document_type: 1=OAuth, 2=email, 3=ID/license, 4=passport, 5=reserved
  // Stored at verification time, used during ZK proof generation
  authority_level Int @default(1) @map("authority_level")

  // === GRADUATED TRUST (see docs/architecture/graduated-trust.md) ===
  trust_tier Int @default(1) @map("trust_tier")
  // 0=guest(conceptual), 1=authenticated, 2=address-attested, 3=identity-verified, 4=passport-verified, 5=gov-credential

  // === PASSKEY / WEBAUTHN (Tier 1) ===
  passkey_credential_id  String?   @unique @map("passkey_credential_id")
  passkey_public_key_jwk Json?     @map("passkey_public_key_jwk")
  did_key                String?   @unique @map("did_key")
  passkey_created_at     DateTime? @map("passkey_created_at")
  passkey_last_used_at   DateTime? @map("passkey_last_used_at")

  // === ADDRESS ATTESTATION (Tier 2) ===
  address_verification_method String?   @map("address_verification_method") // 'civic_api' | 'postal' | 'mdl'
  address_verified_at         DateTime? @map("address_verified_at")

  // === WALLET & ACCOUNT FIELDS ===
  wallet_address String? @unique @map("wallet_address") // EVM wallet (MetaMask/WC binding)
  wallet_type    String? @map("wallet_type") // 'evm' | 'near' | null
  district_hash     String? @map("district_hash") // HMAC-SHA256(district, DISTRICT_HASH_KEY) — rainbow-table resistant

  // === PII ENCRYPTION AT REST (C-3, scrubbed Cycle 6) ===
  encrypted_email   String? @map("encrypted_email") // AES-256-GCM JSON { ciphertext, iv } — nullable until backfill complete
  encrypted_name    String? @map("encrypted_name")  // AES-256-GCM JSON { ciphertext, iv }
  email_hash        String? @unique @map("email_hash") // HMAC-SHA256(normalize(email), EMAIL_LOOKUP_KEY) — nullable until backfill complete
  encrypted_profile String? @map("encrypted_profile") // C-4: AES-256-GCM JSON blob { role, organization, location, connection }

  // === NEAR ACCOUNT (Paths 1 + 3: invisible account for non-crypto / non-EVM users) ===
  near_account_id             String? @unique @map("near_account_id") // Implicit account ID (64-char hex pubkey)
  near_public_key             String? @map("near_public_key") // Ed25519 public key (base58 or hex)
  encrypted_near_private_key  String? @map("encrypted_near_private_key") // AES-256-GCM encrypted primary key
  near_recovery_public_key    String? @map("near_recovery_public_key") // FunctionCall recovery key (server-held)
  near_derived_scroll_address String? @map("near_derived_scroll_address") // Scroll address from Chain Signatures
  trust_score                 Int     @default(0) @map("trust_score")
  reputation_tier             String  @default("novice") @map("reputation_tier")

  // === ZERO-KNOWLEDGE VERIFICATION (Phase 1) ===
  district_verified Boolean @default(false) @map("district_verified") // ZK proof verification status

  // === PHASE 1 REPUTATION FIELDS (Concrete Signals Only) ===
  templates_contributed  Int   @default(0) @map("templates_contributed") // Count
  template_adoption_rate Float @default(0.0) @map("template_adoption_rate") // % of templates others used
  peer_endorsements      Int   @default(0) @map("peer_endorsements") // On-chain attestations
  active_months          Int   @default(0) @map("active_months") // Engagement velocity

  // === PROFILE FIELDS ===
  role                 String?
  organization         String?
  location             String? // General location description (city-level, not PII)
  connection           String?
  profile_completed_at DateTime? @map("profile_completed_at")
  profile_visibility   String    @default("private") @map("profile_visibility")

  // === RELATIONS (keep existing) ===
  account         account[]
  sessions        Session[]
  templates       Template[]
  campaigns       template_campaign[]    @relation("UserCampaigns")
  dmRelations     UserDMRelation[]       @relation("UserDMRelations")

  // === AGENTIC DELEGATION (Phase A) ===
  delegationGrants DelegationGrant[]

  // === ORG LAYER ===
  memberships  OrgMembership[]
  subscription Subscription?

  // Encrypted identity blob (Phase 1: Postgres, Phase 2: IPFS)
  encrypted_delivery_data EncryptedDeliveryData?

  // === DISTRICT CREDENTIALS (Tier 2: Address-Attested) ===
  district_credentials DistrictCredential[]

  verification_sessions VerificationSession[]

  // === SHADOW ATLAS REGISTRATION (Three-Tree ZK Architecture) ===
  shadow_atlas_registration ShadowAtlasRegistration?

  // === VERIFICATION AUDIT (Compliance Trail) ===
  verification_audits VerificationAudit[]

  // === SEGMENTS ===
  segments Segment[]

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Template {
  id               String    @id @default(cuid())
  slug             String    @unique
  title            String
  description      String
  category         String
  topics           Json?     @default("[]") // Topic tags for search/filtering (1-5 lowercase strings)
  type             String
  deliveryMethod   String    @map("delivery_method")
  preview          String
  message_body     String
  sources          Json?     @default("[]") // Citation sources from message generation agent
  research_log     Json?     @default("[]") @map("research_log") // Agent's research process log
  cachedSources    Json?     @map("cached_sources") // Evaluated source pool from first generation
  sourcesCachedAt  DateTime? @map("sources_cached_at") // Cache timestamp (72h TTL)
  delivery_config  Json
  cwc_config       Json?
  recipient_config Json
  metrics          Json
  campaign_id      String?
  status           String    @default("draft")
  is_public        Boolean   @default(false)

  // Aggregate community metrics (NO individual user tracking)
  verified_sends   Int    @default(0) @map("verified_sends") // Total verified messages sent
  unique_districts Int    @default(0) @map("unique_districts") // Unique districts reached
  avg_reputation   Float? @map("avg_reputation") // Average sender reputation

  // Semantic embeddings for pgvector HNSW search (768-dim Gemini vectors)
  // Indexes: HNSW on topic_embedding + location_embedding — added via raw SQL
  location_embedding    Unsupported("vector(768)")? @map("location_embedding")
  topic_embedding       Unsupported("vector(768)")? @map("topic_embedding")
  embedding_version     String                      @default("v1") @map("embedding_version")
  embeddings_updated_at DateTime?                   @map("embeddings_updated_at")

  // === STATUS AND TRACKING ===
  verification_status String?   @default("pending") @map("verification_status") // 'pending', 'approved', 'rejected'
  country_code        String?   @default("US") @map("country_code")
  reviewed_at         DateTime? @map("reviewed_at")
  reviewed_by         String?   @map("reviewed_by")

  // === PHASE 1 MODERATION (safety only, NOT quality) ===
  flagged_by_moderation Boolean @default(false) @map("flagged_by_moderation") // OpenAI API flagged
  consensus_approved    Boolean @default(false) @map("consensus_approved") // Multi-agent approved (binary)

  // Reputation impact (Phase 1: on-chain ERC-8004, no token rewards)
  reputation_delta   Float   @default(0) @map("reputation_delta")
  reputation_applied Boolean @default(false) @map("reputation_applied")

  // Content-addressable identity: SHA-256(title + body), prevents duplicate publishing
  content_hash String? @map("content_hash")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // User relationship
  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id])

  // Org relationship (dual ownership: user + org)
  orgId String?       @map("org_id")
  org   Organization? @relation("OrgTemplates", fields: [orgId], references: [id])

  // === EXISTING RELATIONS (preserve all) ===
  template_campaign template_campaign[]

  // Power Landscape: position registrations (Cycle 37)
  positionRegistrations PositionRegistration[]

  // NEW: Structured jurisdictions (replaces deprecated string arrays)
  jurisdictions TemplateJurisdiction[]

  // NEW: International geographic scope (agent-extracted, breadcrumb filtering)
  scopes TemplateScope[]

  // NEW: Verifiable messages (pseudonymous, NO user linkage)
  messages Message[]

  // Staked deliberation (DebateMarket.sol off-chain content storage)
  debates Debate[]

  // Coalition endorsements (many orgs can endorse one template)
  endorsements TemplateEndorsement[]

  @@unique([userId, content_hash], name: "template_author_content")
  @@index([verification_status])
  @@index([country_code])
  @@index([userId])
  @@map("template")
}

// ============= VERIFIABLE MESSAGE MODEL =============
// Per CYPHERPUNK-ARCHITECTURE.md: Messages are PUBLIC, pseudonymous, and verifiable
// NO user_id linkage - can't trace who sent individual messages
// Congressional offices read PUBLIC content + verification proof

model Message {
  id          String @id @default(cuid())
  template_id String @map("template_id")

  // PUBLIC message content (plaintext, readable by offices + moderation)
  content String // Actual message body sent
  subject String? // Email subject (if applicable)

  // CRYPTOGRAPHIC VERIFICATION (stored for later verification)
  verification_proof String @map("verification_proof") // ZK proof of district membership
  district_hash      String @map("district_hash") // SHA-256(district) - NOT plaintext
  reputation_score   Int    @default(0) @map("reputation_score") // Sender's reputation at send time

  // DELIVERY TRACKING (congressional office engagement)
  sent_at              DateTime  @default(now()) @map("sent_at")
  delivered_at         DateTime? @map("delivered_at")
  office_read          Boolean   @default(false) @map("office_read")
  office_responded     Boolean   @default(false) @map("office_responded")
  office_response_time Int?      @map("office_response_time") // Minutes from delivery to response

  // DELIVERY METADATA
  delivery_method   String  @map("delivery_method") // 'cwc' | 'email'
  cwc_submission_id String? @map("cwc_submission_id")
  delivery_status   String  @default("pending") @map("delivery_status") // 'pending', 'delivered', 'failed'
  error_message     String? @map("error_message")

  // Relation to template (aggregates community metrics)
  template Template @relation(fields: [template_id], references: [id], onDelete: Cascade)

  @@index([template_id])
  @@index([district_hash])
  @@index([sent_at])
  @@index([delivery_status])
  @@index([office_read])
  @@map("message")
}

// NEW: Structured jurisdictions for templates (replaces string arrays)
// Enables semantic search, VPN-resistant location matching, and privacy-preserving template discovery
model TemplateJurisdiction {
  id                String @id @default(cuid())
  template_id       String @map("template_id")
  jurisdiction_type String @map("jurisdiction_type") // 'federal' | 'state' | 'county' | 'city' | 'school_district'

  // Federal jurisdictions
  congressional_district String? @map("congressional_district") // "TX-18", "CA-12"
  senate_class           String? @map("senate_class") // "I", "II", "III" (6-year rotation)

  // State jurisdictions
  state_code            String? @map("state_code") // "TX", "CA"
  state_senate_district String? @map("state_senate_district") // State upper house district
  state_house_district  String? @map("state_house_district") // State lower house district

  // County jurisdictions
  county_fips String? @map("county_fips") // 5-digit FIPS code (e.g., "48201" for Harris County, TX)
  county_name String? @map("county_name")

  // City jurisdictions
  city_name String? @map("city_name")
  city_fips String? @map("city_fips") // Census Place FIPS code

  // School district jurisdictions
  school_district_id   String? @map("school_district_id") // NCES district ID
  school_district_name String? @map("school_district_name")

  // Geospatial data (for distance calculations)
  latitude  Float?
  longitude Float?

  // Coverage metadata
  estimated_population BigInt? @map("estimated_population") // Census estimate
  coverage_notes       String? @map("coverage_notes") // Human-readable coverage description

  // Timestamps
  created_at DateTime @default(now()) @map("created_at")
  updated_at DateTime @updatedAt @map("updated_at")

  // Relation to template
  template Template @relation(fields: [template_id], references: [id], onDelete: Cascade)

  // Indexes for efficient querying
  @@index([template_id])
  @@index([jurisdiction_type])
  @@index([congressional_district])
  @@index([state_code])
  @@index([county_fips])
  @@index([city_fips])
  @@index([school_district_id])
  @@map("template_jurisdiction")
}

// ============= INTERNATIONAL GEOGRAPHIC SCOPE (PHASE 1) =============
// Agent-extracted geographic scope for template filtering
// Works internationally: US, UK, France, Japan, Brazil, etc.
// Universal semantic hierarchy: country → region → locality → district

model TemplateScope {
  id          String @id @default(cuid())
  template_id String @map("template_id")

  // UNIVERSAL HIERARCHY (works internationally)
  country_code  String  @map("country_code") // ISO 3166-1 alpha-2: "US", "GB", "FR", "JP", "BR"
  region_code   String? @map("region_code") // "CA" (US), "ENG" (UK), "11" (FR Île-de-France), "13" (JP Tokyo)
  locality_code String? @map("locality_code") // City/municipality FIPS/code
  district_code String? @map("district_code") // Legislative district: "CA-12" (US), "Holborn and St Pancras" (UK)

  // HUMAN-READABLE (agent-extracted, user sees this)
  display_text String @map("display_text") // "California", "CA-12", "London", "São Paulo", "Tokyo"

  // SEMANTIC LEVEL (for filtering, internationally consistent)
  scope_level String @map("scope_level") // 'country' | 'region' | 'locality' | 'district'

  // POWER STRUCTURE CONTEXT (CRITICAL - prevents painful migration later)
  // Open-ended, not an enum - agents can identify any decision-making structure
  power_structure_type String? @map("power_structure_type") // Examples: government, corporate, housing, institutional, labor, nonprofit, advocacy, cooperative, etc.
  audience_filter      String? @map("audience_filter") // Examples: renters, homeowners, workers, residents, shareholders, members, etc.
  scope_notes          String? @map("scope_notes") // Free text for edge cases: "CA-specific corporate policy", "Renters in rent-controlled buildings"

  // AGENT CONFIDENCE (for validation, not just edit affordance)
  confidence        Float   @default(0.8)
  extraction_method String  @default("regex") @map("extraction_method") // 'regex' | 'fuzzy' | 'geocoder' | 'llm' | 'user_confirmed'
  validated_against String? @map("validated_against") // 'ip_location' | 'oauth_location' | 'verified_address' | 'user_edit'

  // OPTIONAL ENRICHMENT
  estimated_reach BigInt? @map("estimated_reach")
  latitude        Float?
  longitude       Float?

  created_at DateTime @default(now()) @map("created_at")
  updated_at DateTime @updatedAt @map("updated_at")

  template Template @relation(fields: [template_id], references: [id], onDelete: Cascade)

  @@index([template_id])
  @@index([country_code, scope_level])
  @@index([country_code, region_code])
  @@index([district_code])
  @@index([power_structure_type])
  @@index([extraction_method])
  @@map("template_scope")
}

model account {
  id                  String   @id
  user_id             String
  type                String
  provider            String
  provider_account_id String
  expires_at          Int?
  token_type          String?
  scope               String?
  session_state       String?

  // Encrypted token columns (AES-256-GCM via HKDF-derived per-account keys)
  // Stores { ciphertext: string, iv: string } JSON objects
  // Plaintext columns scrubbed in Cycle 6
  encrypted_access_token  Json?
  encrypted_refresh_token Json?
  encrypted_id_token      Json?

  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  // === SYBIL RESISTANCE: Email Verification Tracking (ISSUE-002) ===
  // Twitter allows accounts without verified email, creating synthetic emails
  // like username@twitter.local. These accounts get lower trust_score to
  // prevent Sybil attacks while still allowing basic functionality.
  email_verified Boolean @default(true) @map("email_verified") // false for synthetic emails (e.g., Twitter without email)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([provider, provider_account_id])
}

model template_campaign {
  id              String    @id
  template_id     String
  user_id         String
  pseudonym_id    String?   @map("pseudonym_id") // HMAC-SHA256(user_id, CAMPAIGN_PSEUDONYM_KEY)
  delivery_type   String
  recipient_id    String?
  cwc_delivery_id String?
  status          String    @default("pending")
  sent_at         DateTime?
  delivered_at    DateTime?
  error_message   String?
  metadata        Json?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  template        Template  @relation(fields: [template_id], references: [id], onDelete: Cascade)
  user            User      @relation("UserCampaigns", fields: [user_id], references: [id], onDelete: Cascade)

  @@index([pseudonym_id])
}

model UserDMRelation {
  id              String    @id @default(cuid())
  userId          String    @map("user_id")
  decisionMakerId String    @map("decision_maker_id")
  relationship    String    // "constituent" | "voter" | "resident"
  isActive        Boolean   @default(true) @map("is_active")
  assignedAt      DateTime  @default(now()) @map("assigned_at")
  lastValidated   DateTime? @map("last_validated")

  // Cycle 5 C-2d: Track origin of DM relationship
  source String @default("legacy") // "legacy" | "shadow_atlas" | "civic_api"

  user          User          @relation("UserDMRelations", fields: [userId], references: [id], onDelete: Cascade)
  decisionMaker DecisionMaker @relation(fields: [decisionMakerId], references: [id], onDelete: Cascade)

  @@unique([userId, decisionMakerId])
  @@index([userId])
  @@index([decisionMakerId])
  @@map("user_dm_relation")
}

// ===================================================================
// EXPERIMENTAL RESEARCH TABLES REMOVED (Phase 0.1 Cleanup)
// The following 8 tables were removed as they had zero production usage:
// - political_field_state (field theory simulation)
// - local_political_bubble (echo chamber detection)
// - community_intersection (community overlap analysis)
// - political_dead_end (propagation boundary detection)
// - community_lifecycle (community growth/decline tracking)
// - user_context_stack (sheaf-theoretic user context)
// - political_flow (vector field visualization)
// - political_uncertainty (quantum-inspired persuadability)
//
// See docs/CODEBASE-AUDIT-PHASE-0.md for complete removal documentation
// ===================================================================

model legislative_channel {
  id                    String    @id @default(cuid())
  country_code          String    @unique
  country_name          String
  legislature_name      String
  legislature_type      String
  access_method         String
  access_tier           Int       @default(3)
  email_pattern         String?
  email_domain          String?
  email_format_notes    String?
  api_endpoint          String?
  api_auth_type         String?
  api_documentation_url String?
  rate_limit_requests   Int?
  rate_limit_daily      Int?
  form_url              String?
  form_requires_captcha Boolean   @default(false)
  form_max_length       Int?
  primary_language      String
  supported_languages   String[]
  requires_constituent  Boolean   @default(false)
  requires_real_address Boolean   @default(false)
  forbidden_words       String[]  @default([])
  message_guidelines    String?
  population            BigInt?
  internet_penetration  Float?
  democracy_index       Float?
  is_active             Boolean   @default(true)
  last_verified         DateTime?
  created_at            DateTime  @default(now()) @map("created_at")
  updated_at            DateTime  @updatedAt @map("updated_at")

  @@index([access_tier, is_active])
  @@index([country_code])
  @@map("legislative_channel")
}

// ANALYTICS MODELS (Legacy models removed - see analytics_aggregate for privacy-first replacement)

// =============================================================================
// PRIVACY-FIRST ANALYTICS SCHEMA (Wave 1)
// =============================================================================
// These models REPLACE the legacy analytics_session, analytics_event, and
// analytics_experiment tables. Legacy tables kept temporarily for migration.
// See docs/specs/privacy-first-analytics.md for full specification.

/// Daily aggregate metrics - the ONLY analytics data we store
/// No individual events, no sessions, no user tracking
model analytics_aggregate {
  id String @id @default(cuid())

  // Time bucket (day granularity - never finer)
  date DateTime @db.Date

  // Metric dimensions (empty string = not specified)
  metric          String // e.g., "template_view", "funnel_3", "delivery_success"
  template_id     String @default("") // For template-specific metrics
  jurisdiction    String @default("") // Geographic rollup (district, state, region, national)
  delivery_method String @default("") // For delivery metrics
  utm_source      String @default("") // For acquisition metrics
  error_type      String @default("") // For error metrics

  // The only value we store: a count
  count Int @default(0)

  // Differential privacy metadata
  noise_applied Float @default(0) // Laplace noise applied to count
  epsilon       Float @default(1.0) // Privacy budget consumed

  // Composite unique constraint prevents duplicates
  @@unique([date, metric, template_id, jurisdiction, delivery_method, utm_source, error_type])
  // Query optimization indexes
  @@index([date])
  @@index([metric, date])
  @@index([template_id, date])
  @@index([jurisdiction, date])
  @@map("analytics_aggregate")
}

// =============================================================================
// PRIVACY BUDGET ENFORCEMENT (Wave 2: Differential Privacy)
// =============================================================================
// These models implement a CQRS pattern to prevent "infinite budget" attacks:
//
// WRITE PATH:
//   Raw increments → analytics_aggregate (no noise)
//
// MATERIALIZE PATH (Daily Cron):
//   1. Read raw counts from analytics_aggregate
//   2. Apply Laplace noise ONCE (deterministic seed for auditability)
//   3. Write to analytics_snapshot (immutable after creation)
//   4. Track epsilon spent in privacy_budget
//
// READ PATH:
//   Queries ONLY read from analytics_snapshot (noise already applied)
//   This defeats attacks where repeated queries average out fresh noise
//
// See docs/specs/privacy-first-analytics.md for full specification.
// =============================================================================

/// Pre-noised aggregate data for privacy-preserving queries
/// Noise applied ONCE at materialization, never at query time
/// This defeats "infinite budget" attacks via temporal separation
model analytics_snapshot {
  id String @id @default(cuid())

  // Time bucket (day granularity - never finer)
  snapshot_date DateTime @db.Date

  // Metric dimensions (empty string = not specified)
  metric          String // e.g., "template_view", "funnel_3", "delivery_success"
  template_id     String @default("") // For template-specific metrics
  jurisdiction    String @default("") // Geographic rollup (district, state, region, national)
  delivery_method String @default("") // For delivery metrics
  utm_source      String @default("") // For acquisition metrics
  error_type      String @default("") // For error metrics

  // The noisy count (noise applied once, immutable after creation)
  noisy_count Int

  // Privacy metadata
  epsilon_spent Float // Privacy budget consumed by this snapshot
  noise_seed    String // For auditability - enables deterministic noise reproduction

  created_at DateTime @default(now())

  // Composite unique constraint prevents duplicates
  @@unique([snapshot_date, metric, template_id, jurisdiction, delivery_method, utm_source, error_type])
  // Query optimization indexes
  @@index([snapshot_date])
  @@index([metric, snapshot_date])
  @@index([template_id, snapshot_date])
  @@index([jurisdiction, snapshot_date])
  @@map("analytics_snapshot")
}

/// Daily privacy budget tracking to enforce MAX_DAILY_EPSILON limits
/// Prevents budget exhaustion and tracks query patterns
model privacy_budget {
  id String @id @default(cuid())

  // Budget tracking by day
  budget_date DateTime @unique @db.Date

  // Epsilon accounting
  epsilon_spent Float @default(0) // Total epsilon spent today
  epsilon_limit Float @default(10.0) // Daily limit (configurable)

  // Query tracking
  queries_count Int @default(0) // Number of queries executed

  // Timestamps
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("privacy_budget")
}

// ============= ENCRYPTED IDENTITY BLOBS (PHASE 1) =============
// Per PORTABLE-ENCRYPTED-IDENTITY-ARCHITECTURE.md
// Phase 1: Postgres storage (platform cannot decrypt)
// Phase 2: IPFS + on-chain pointers (portable credentials)

model EncryptedDeliveryData {
  id      String @id @default(cuid())
  user_id String @unique @map("user_id")

  // XChaCha20-Poly1305 encrypted blob
  ciphertext           String @map("ciphertext") // Base64-encoded encrypted data
  nonce                String @map("nonce") // Base64-encoded nonce
  ephemeral_public_key String @map("ephemeral_public_key") // Base64-encoded ephemeral key

  // TEE key used for encryption
  tee_key_id String @map("tee_key_id") // Which TEE public key was used

  // Metadata
  encryption_version String    @default("1.0.0") @map("encryption_version")
  created_at         DateTime  @default(now()) @map("created_at")
  updated_at         DateTime  @updatedAt @map("updated_at")
  last_used_at       DateTime? @map("last_used_at") // When blob was last decrypted in TEE

  // User relation
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([created_at])
  @@index([tee_key_id])
  @@map("encrypted_delivery_data")
}

// ============= ZK PROOF SUBMISSIONS (Phase 1: Encrypted Delivery) =============
// Tracks ZK proof submissions for congressional delivery
// Links proof generation → encrypted blob → delivery → on-chain verification

model Submission {
  id              String @id @default(cuid())
  pseudonymous_id String @map("pseudonymous_id") // SHA-256(user_id + SUBMISSION_ANONYMIZATION_SALT) — unlinkable to auth identity
  template_id     String @map("template_id")

  // === ZERO-KNOWLEDGE PROOF DATA ===
  // Browser-generated Halo2 proof (2-5s in TEE)
  proof_hex     String @map("proof_hex") // Serialized proof (hex string)
  public_inputs Json   @map("public_inputs") // [merkle_root, nullifier, action_id]
  nullifier     String @unique @map("nullifier") // Unique per (identity, action) - prevents double-spend
  action_id     String @map("action_id") // Context for the proof

  // === IDEMPOTENCY ===
  // Prevents duplicate submissions from client retries
  idempotency_key String? @unique @map("idempotency_key") // Client-generated unique key

  // === WITNESS ENCRYPTION (XChaCha20-Poly1305) ===
  // Address encrypted to TEE public key, decrypted only in enclave
  encrypted_witness String  @map("encrypted_witness") // Base64-encoded ciphertext
  encrypted_message String? @map("encrypted_message") // Base64-encoded message (optional if public)

  // Encryption Metadata (Optional for Phase 1 MVP if bundled)
  witness_nonce        String? @map("witness_nonce") // Base64-encoded nonce
  ephemeral_public_key String? @map("ephemeral_public_key") // Base64-encoded ephemeral key
  tee_key_id           String? @map("tee_key_id") // Which TEE key was used

  // === CONGRESSIONAL DELIVERY ===
  // CWC API submission (encrypted delivery through TEE)
  cwc_submission_id String?   @map("cwc_submission_id") // CWC API submission ID
  delivery_status   String    @default("pending") @map("delivery_status") // 'pending' | 'processing' | 'delivered' | 'partial' | 'failed'
  delivery_error    String?   @map("delivery_error") // Error message if failed
  delivered_at      DateTime? @map("delivered_at")

  // === BLOCKCHAIN VERIFICATION ===
  // On-chain proof verification (Scroll zkEVM)
  verification_tx_hash String?   @map("verification_tx_hash") // Scroll transaction hash
  verification_status  String    @default("pending") @map("verification_status") // 'pending' | 'verified' | 'rejected'
  verified_at          DateTime? @map("verified_at")
  block_number         Int?      @map("block_number")

  // === REPUTATION TRACKING ===
  // On-chain ERC-8004 reputation update (Phase 1: no token rewards)
  reputation_delta   Int?    @map("reputation_delta") // Reputation change (+5, +10, etc.)
  reputation_tx_hash String? @map("reputation_tx_hash") // Reputation update transaction

  // === WITNESS EXPIRY ===
  // Encrypted witness data auto-expires after 30 days for data minimization.
  // Cleanup cron NULLs out encrypted_witness, witness_nonce, ephemeral_public_key.
  // Proof, nullifier, and delivery status are preserved (not PII).
  witness_expires_at DateTime? @map("witness_expires_at")

  // === METADATA ===
  created_at DateTime @default(now()) @map("created_at")
  updated_at DateTime @updatedAt @map("updated_at")

  retry SubmissionRetry?

  @@index([pseudonymous_id])
  @@index([template_id])
  @@index([delivery_status])
  @@index([verification_status])
  @@index([created_at])
  @@index([witness_expires_at])
  @@map("submission")
}

// ============= VERIFICATION SESSION (Phase 1A) =============
// Ephemeral sessions for self.xyz and Didit verification flows
// 5-minute expiration prevents replay attacks

model VerificationSession {
  id         String   @id @default(cuid())
  user_id    String   @map("user_id")
  nonce      String   @unique // Cryptographic nonce (prevents replay attacks)
  challenge  String // QR code data / verification challenge
  expires_at DateTime @map("expires_at") // 5-minute expiration (security best practice)
  status     String   @default("pending") // 'pending' | 'verified' | 'expired' | 'failed'
  method     String // 'self.xyz' | 'didit'
  created_at DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, created_at])
  @@index([expires_at]) // For cleanup job
  @@map("verification_session")
}

// ============= DISTRICT CREDENTIAL (Wave 3A: Address-Attested Tier 2) =============
// Verifiable credential for district residency, issued after address verification
// Supports both Civic API instant verification and postal verification
// Credentials expire and can be revoked; credential_hash enables offline verification

model DistrictCredential {
  id                      String    @id @default(cuid())
  user_id                 String    @map("user_id")
  credential_type         String    @default("district_residency") @map("credential_type")
  congressional_district  String    @map("congressional_district") // Plaintext — kept during transition, drop after TTL
  state_senate_district   String?   @map("state_senate_district")  // Plaintext — kept during transition
  state_assembly_district String?   @map("state_assembly_district") // Plaintext — kept during transition
  verification_method     String    @map("verification_method") // 'civic_api' | 'postal'
  issued_at               DateTime  @default(now()) @map("issued_at")
  expires_at              DateTime  @map("expires_at")
  revoked_at              DateTime? @map("revoked_at")
  credential_hash         String    @map("credential_hash") // SHA-256 of the VC JSON

  // B-2: Privacy-preserving district storage (replaces plaintext columns after TTL)
  district_commitment     String?   @map("district_commitment") // Poseidon2_sponge_24(districts[0..24])
  slot_count              Int?      @map("slot_count")          // How many of 24 slots are non-zero

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, expires_at])
  @@index([congressional_district])
  @@map("district_credential")
}

// ============= DISTRIBUTED RATE LIMITING (Postgres-Based) =============
// Multi-instance rate limiting using existing Neon Postgres
// See docs/architecture/rate-limiting.md for design rationale
//
// WHY NOT REDIS:
// - Single person maintaining, operational overhead matters
// - Neon Postgres already available (zero additional cost)
// - For DP contribution limits, approximate enforcement is acceptable
// - Privacy guarantees come from DP noise, not exact rate limits
//
// USAGE:
// - Analytics contribution limits (MAX_DAILY_CONTRIBUTIONS per identifier)
// - API rate limiting for sensitive endpoints
// - Template submission throttling
//
// CLEANUP:
// - Daily cron job deletes entries older than 2 days
// - See src/routes/api/cron/cleanup-rate-limits for implementation

model RateLimit {
  id String @id @default(cuid())

  // Composite key: identifier (hashed IP) + metric type
  key String // Format: "sha256(ip):metric_name" or "sha256(ip):endpoint"

  // Time window (day granularity for daily limits)
  window_start DateTime @map("window_start") @db.Date

  // Counter (incremented atomically via upsert)
  count Int @default(1)

  // Timestamps
  created_at DateTime @default(now()) @map("created_at")
  updated_at DateTime @updatedAt @map("updated_at")

  // Composite unique constraint for upsert
  @@unique([key, window_start])
  // Index for cleanup queries (delete old windows)
  @@index([window_start])
  @@map("rate_limits")
}

// ============================================================================
// Intelligence (migrated from MongoDB — pgvector for embeddings)
// ============================================================================

model Intelligence {
  id               String                      @id @default(cuid())
  category         String // 'news' | 'legislative' | 'regulatory' | 'corporate' | 'social'
  title            String
  source           String
  source_url       String
  published_at     DateTime
  snippet          String
  topics           String[] // Postgres array
  entities         String[] // Postgres array
  embedding        Unsupported("vector(768)")?
  relevance_score  Float?
  sentiment        String? // 'positive' | 'negative' | 'neutral' | 'mixed'
  geographic_scope String?
  created_at       DateTime                    @default(now())
  expires_at       DateTime?

  // Full-text search: generated tsvector column added via raw SQL migration
  // Indexes: HNSW on embedding, GIN on tsvector, GIN on topics — added via raw SQL

  @@index([category])
  @@index([published_at])
  @@index([relevance_score])
  @@index([expires_at])
  @@map("intelligence")
}

// ============================================================================
// Parsed Document Cache (migrated from MongoDB — JSONB storage)
// ============================================================================

model ParsedDocumentCache {
  id               String    @id @default(cuid())
  source_url       String
  source_url_hash  String    @unique
  document_type    String // 'legislative' | 'official' | 'media' | 'corporate' | 'academic'
  document         Json // Full ParsedDocument as JSONB
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt
  expires_at       DateTime
  hit_count        Int       @default(0)
  last_accessed_at DateTime?

  @@index([source_url])
  @@index([document_type])
  @@index([expires_at])
  @@map("parsed_document_cache")
}

// ============================================================================
// Resolved Contact Cache — Persists email discoveries across pipeline runs
// 14-day TTL. Keyed on normalized org + title for upsert.
// ============================================================================

model ResolvedContact {
  id                 String    @id @default(cuid())
  orgKey             String    @map("org_key")
  name               String?
  title              String?
  email              String?
  emailSource        String?   @map("email_source")
  verificationStatus String?   @map("verification_status") // "deliverable" | "undeliverable" | "risky" | "unknown"
  verifiedAt         DateTime? @map("verified_at")
  resolvedAt         DateTime  @default(now()) @map("resolved_at")
  expiresAt          DateTime  @map("expires_at")

  @@unique([orgKey, title])
  @@index([expiresAt])
  @@map("resolved_contact")
}

// ============================================================================
// Suppressed Emails — Permanently suppress known-bad email addresses
// Sources: SMTP verification (6mo TTL), user bounce reports (1yr TTL)
// ============================================================================

model SuppressedEmail {
  id          String   @id @default(cuid())
  email       String   @unique
  domain      String
  reason      String // "smtp_invalid" | "smtp_disabled" | "full_inbox" | "bounce_report" | "dns_no_mx"
  source      String // "verification" | "user_report"
  reportedBy  String?  @map("reported_by")
  reacherData Json?    @map("reacher_data")
  createdAt   DateTime @default(now()) @map("created_at")
  expiresAt   DateTime @map("expires_at")

  @@index([domain])
  @@index([expiresAt])
  @@map("suppressed_email")
}

// ============================================================================
// Agent Trace — Fire-and-forget observability for LLM agent pipelines
// Tracks requests, completions, costs, and errors per traceId.
// TTL-based: AGENT_TRACE_TTL_DAYS (default 30), purged by daily cron.
// ============================================================================

model AgentTrace {
  id         String   @id @default(cuid())
  traceId    String   @map("trace_id")
  userId     String?  @map("user_id")
  endpoint   String
  eventType  String   @map("event_type")
  payload    Json     @default("{}")
  success    Boolean?
  durationMs Int?     @map("duration_ms")
  costUsd    Float?   @map("cost_usd")
  createdAt  DateTime @default(now()) @map("created_at")
  expiresAt  DateTime @map("expires_at")

  @@index([traceId])
  @@index([userId, createdAt])
  @@index([endpoint, createdAt])
  @@index([eventType, createdAt])
  @@index([expiresAt])
  @@map("agent_trace")
}

// ============================================================================
// Staked Deliberation — DebateMarket.sol off-chain content storage
// Arguments are content-addressed: body stored here, bodyHash stored on-chain.
// No CoSign model — co-signs are on-chain only (stakeRecords mapping).
// Aggregate caches (co_sign_count, total_stake) updated by event indexer.
// ============================================================================

model Debate {
  id          String @id @default(cuid())
  template_id String @map("template_id")

  // On-chain identifiers
  debate_id_onchain String @unique @map("debate_id_onchain") // bytes32 from proposeDebate()
  action_domain     String @map("action_domain") // Derived debate action domain (BN254)
  proposition_hash  String @map("proposition_hash") // keccak256(proposition_text)

  // Proposition content (stored off-chain, hash on-chain)
  proposition_text String @map("proposition_text")

  // Debate parameters
  deadline          DateTime
  jurisdiction_size Int      @default(0) @map("jurisdiction_size")
  status            String   @default("active") // 'active' | 'resolving' | 'resolved' | 'awaiting_governance' | 'under_appeal'

  // Aggregate metrics (mirrors on-chain, updated via event indexer)
  argument_count      Int    @default(0) @map("argument_count")
  unique_participants Int    @default(0) @map("unique_participants")
  total_stake         BigInt @default(0) @map("total_stake")

  // Resolution (populated after resolveDebate())
  winning_argument_index Int?      @map("winning_argument_index")
  winning_stance         String?   @map("winning_stance")
  resolved_at            DateTime? @map("resolved_at")
  resolved_from_chain    Boolean   @default(false) @map("resolved_from_chain") // True when winner confirmed by on-chain read

  // AI Resolution (Phase 3: AI-Augmented Resolution)
  ai_resolution            Json?     @map("ai_resolution") // Full AIResolutionData blob
  ai_signature_count       Int?      @map("ai_signature_count")
  ai_panel_consensus       Float?    @map("ai_panel_consensus") // Model agreement 0-1
  resolution_method        String?   @map("resolution_method") // 'ai_community' | 'governance_override'
  appeal_deadline          DateTime? @map("appeal_deadline")
  governance_justification String?   @map("governance_justification")

  // Transaction (populated when created on-chain)
  tx_hash String? @map("tx_hash") // proposeDebate() transaction hash

  // Proposer (pseudonymous — wallet address, not identity)
  proposer_address String @map("proposer_address")
  proposer_bond    BigInt @map("proposer_bond")

  // LMSR market state (populated after first epoch)
  market_status       String    @default("pre_market") @map("market_status") // 'pre_market' | 'active' | 'resolved'
  market_liquidity    BigInt?   @map("market_liquidity") // LMSR b parameter (SD59x18 raw)
  current_prices      Json?     @map("current_prices") // { "0": "0.333", "1": "0.333", "2": "0.333" }
  current_epoch       Int       @default(0) @map("current_epoch")
  trade_deadline      DateTime? @map("trade_deadline") // current epoch commit deadline
  resolution_deadline DateTime? @map("resolution_deadline") // market resolution deadline

  // Timestamps
  created_at DateTime @default(now()) @map("created_at")
  updated_at DateTime @updatedAt @map("updated_at")

  // Relations
  template   Template          @relation(fields: [template_id], references: [id], onDelete: Cascade)
  arguments  DebateArgument[]
  nullifiers DebateNullifier[]
  campaign   Campaign?

  @@index([template_id])
  @@index([status])
  @@index([debate_id_onchain])
  @@map("debate")
}

model DebateArgument {
  id             String @id @default(cuid())
  debate_id      String @map("debate_id")
  argument_index Int    @map("argument_index") // On-chain index in debate.arguments[]

  // Content (stored off-chain, bodyHash on-chain)
  stance         String // 'SUPPORT' | 'OPPOSE' | 'AMEND'
  body           String
  body_hash      String  @map("body_hash") // keccak256(body)
  amendment_text String? @map("amendment_text") // Only for AMEND stance
  amendment_hash String? @map("amendment_hash")
  nullifier_hash String? @map("nullifier_hash")

  // Scoring (from on-chain events, updated by indexer)
  stake_amount    BigInt @map("stake_amount")
  engagement_tier Int    @map("engagement_tier")
  weighted_score  BigInt @map("weighted_score") // sqrt(stake) * 2^tier
  total_stake     BigInt @default(0) @map("total_stake") // Including co-signs
  co_sign_count   Int    @default(0) @map("co_sign_count")

  // LMSR pricing (updated by chain event indexer)
  current_price  String? @map("current_price") // "0.42" (decimal string)
  price_history  Json?   @map("price_history") // [{ epoch: 0, price: "0.333", timestamp: "..." }, ...]
  position_count Int     @default(0) @map("position_count") // total unique traders on this argument

  // AI evaluation scores (Phase 3: AI-Augmented Resolution)
  ai_scores       Json?  @map("ai_scores") // { reasoning, accuracy, evidence, constructiveness, feasibility }
  ai_weighted     Int?   @map("ai_weighted") // Dimension-weighted AI score (0-10000 bp)
  final_score     Int?   @map("final_score") // α-blended final score (0-10000 bp)
  model_agreement Float? @map("model_agreement") // Fraction of models within 20% of median (0-1)

  // On-chain verification status (Q1 integrity fix — prevents unverified
  // data from influencing resolution or display)
  verification_status String    @default("pending") @map("verification_status") // 'pending' | 'verified' | 'rejected'
  verified_at         DateTime? @map("verified_at")

  // Timestamps
  created_at DateTime @default(now()) @map("created_at")

  // Relations
  debate Debate @relation(fields: [debate_id], references: [id], onDelete: Cascade)

  @@unique([debate_id, argument_index])
  @@unique([debate_id, nullifier_hash])
  @@index([debate_id])
  @@index([weighted_score])
  @@index([verification_status])
  @@map("debate_argument")
}

// =============================================================================
// Debate Nullifier Dedup — tracks all ZK nullifiers per debate to enforce
// one-action-per-identity (arguments + co-signs share the same constraint).
// PostgreSQL treats NULL != NULL in unique constraints, so existing rows
// without nullifiers won't conflict.
// =============================================================================

model DebateNullifier {
  id             String @id @default(cuid())
  debate_id      String @map("debate_id")
  nullifier_hash String @map("nullifier_hash")
  action_type    String @map("action_type") // 'argument' | 'cosign'

  // On-chain verification (Q1 integrity fix)
  verification_status String  @default("pending") @map("verification_status") // 'pending' | 'verified' | 'rejected'
  cosign_weight       BigInt? @map("cosign_weight") // Weight contributed by this cosign (for rollback)
  argument_id         String? @map("argument_id") // Target argument (for cosign weight rollback)
  tx_hash             String? @map("tx_hash") // Transaction hash for async verification

  created_at DateTime @default(now()) @map("created_at")

  debate Debate @relation(fields: [debate_id], references: [id], onDelete: Cascade)

  @@unique([debate_id, nullifier_hash])
  @@index([debate_id])
  @@index([verification_status])
  @@map("debate_nullifier")
}

// =============================================================================
// SHADOW ATLAS REGISTRATION (Three-Tree Architecture)
// =============================================================================

/// Tracks user registration in the Shadow Atlas identity tree (Tree 1).
/// The leaf hash is Poseidon2_H4(user_secret, cell_id, registration_salt, authority_level),
/// computed entirely in the browser. Only the leaf hash and Merkle proof are stored here.
model ShadowAtlasRegistration {
  id                     String   @id @default(cuid())
  user_id                String   @unique @map("user_id")
  congressional_district String   @map("congressional_district")
  identity_commitment    String   @map("identity_commitment")
  leaf_index             Int      @map("leaf_index")
  merkle_root            String   @map("merkle_root")
  merkle_path            Json     @map("merkle_path") // string[] of sibling hashes
  credential_type        String   @map("credential_type") // 'three-tree'
  cell_id                String?  @map("cell_id") // Census block GEOID (nullable for privacy)
  verification_method    String   @map("verification_method") // 'mdl' | 'digital-credentials-api'
  verification_id        String   @map("verification_id")
  verification_timestamp DateTime @map("verification_timestamp")
  registration_status    String   @default("registered") @map("registration_status")
  expires_at             DateTime @map("expires_at")
  created_at             DateTime @default(now()) @map("created_at")
  updated_at             DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([identity_commitment])
  @@index([registration_status])
  @@map("shadow_atlas_registration")
}

// =============================================================================
// VERIFICATION AUDIT (Compliance Trail)
// =============================================================================

/// Audit log for identity verification events. Tracks verification attempts
/// and outcomes for compliance reporting. No PII stored — only method, result,
/// and timestamps.
model VerificationAudit {
  id                  String   @id @default(cuid())
  user_id             String   @map("user_id")
  verification_method String   @map("verification_method")
  result              String   @map("result") // 'success' | 'failure' | 'expired'
  error_code          String?  @map("error_code")
  ip_hash             String?  @map("ip_hash") // SHA-256 of IP for rate limiting, not PII
  created_at          DateTime @default(now()) @map("created_at")

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([created_at])
  @@map("verification_audit")
}

// ============= SUBMISSION RETRY QUEUE =============
// Database-backed retry queue for failed blockchain submissions.
// Exponential backoff: 30s, 60s, 120s, 240s → exhausted after 4 attempts.
// Idempotency via nullifier check against on-chain state.

model SubmissionRetry {
  id             String   @id @default(cuid())
  submission_id  String   @unique @map("submission_id")
  nullifier      String   @map("nullifier")
  proof_hex      String   @map("proof_hex")
  public_inputs  Json     @map("public_inputs") // string[] — 31 field elements (three-tree circuit)
  verifier_depth Int      @map("verifier_depth")
  retry_count    Int      @default(0) @map("retry_count")
  next_retry_at  DateTime @map("next_retry_at")
  status         String   @default("pending") @map("status") // 'pending' | 'succeeded' | 'exhausted'
  last_error     String?  @map("last_error")
  created_at     DateTime @default(now()) @map("created_at")
  updated_at     DateTime @updatedAt @map("updated_at")

  submission Submission @relation(fields: [submission_id], references: [id], onDelete: Cascade)

  @@index([status, next_retry_at])
  @@index([nullifier])
  @@map("submission_retry")
}

// =============================================================================
// POWER LANDSCAPE — Position Registration (Cycle 37)
// =============================================================================
// Tracks citizens who register a position (support/oppose) on a template.
// Keyed by identity_commitment (privacy-preserving, no user_id linkage).
// One position per identity per template (enforced by unique constraint).

model PositionRegistration {
  id                  String   @id @default(cuid())
  template_id         String   @map("template_id")
  identity_commitment String   @map("identity_commitment")
  stance              String // 'support' | 'oppose'
  district_code       String?  @map("district_code")
  registered_at       DateTime @default(now()) @map("registered_at")

  deliveries PositionDelivery[]
  template   Template           @relation(fields: [template_id], references: [id], onDelete: Cascade)

  @@unique([template_id, identity_commitment])
  @@index([template_id])
  @@map("position_registration")
}

model PositionDelivery {
  id              String    @id @default(cuid())
  registration_id String    @map("registration_id")
  recipient_name  String    @map("recipient_name")
  recipient_email String?   @map("recipient_email")
  delivery_method String    @map("delivery_method") // 'cwc' | 'email' | 'recorded'
  delivery_status String    @default("pending") @map("delivery_status") // 'pending' | 'delivered' | 'failed'
  delivered_at    DateTime? @map("delivered_at")

  registration PositionRegistration @relation(fields: [registration_id], references: [id], onDelete: Cascade)

  @@index([registration_id])
  @@map("position_delivery")
}

// ═══════════════════════════════════════════════════════════════════════════
// COMMUNITY FIELD — ZK-verified bubble density aggregation
// ═══════════════════════════════════════════════════════════════════════════
// Tracks BubbleMembershipProof contributions per epoch. The proof verifies
// the user is a real person (Tree 3 engagement) and their bubble maps to
// committed H3 cells. epoch_nullifier prevents double-contribution.
// Privacy-preserving: no user_id linkage, keyed by epoch_nullifier.

model CommunityFieldContribution {
  id                  String   @id @default(cuid())
  epoch_date          String   @map("epoch_date") // "2026-03-02" (daily epoch)
  epoch_nullifier     String   @map("epoch_nullifier") // H2(identity_commitment, epoch_domain)
  cell_tree_root      String   @map("cell_tree_root") // Poseidon Merkle root over H3 cells
  proof_hash          String   @map("proof_hash") // SHA-256(proof) for reference
  verification_status String   @default("pending") @map("verification_status") // 'pending' | 'verified' | 'rejected'
  created_at          DateTime @default(now()) @map("created_at")

  @@unique([epoch_date, epoch_nullifier])
  @@index([epoch_date])
  @@index([verification_status])
  @@map("community_field_contribution")
}

// ============= ORG LAYER MODELS =============
// Per docs/architecture/org-data-model.md
// Orgs are collections, not containers. Users affiliate, not belong.

model Organization {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?
  avatar      String?

  // Billing
  billing_email      String? @map("billing_email")
  stripe_customer_id String? @unique @map("stripe_customer_id")

  // Limits (set per-customer)
  max_seats           Int @default(5) @map("max_seats")
  max_templates_month Int @default(100) @map("max_templates_month")
  dm_cache_ttl_days   Int @default(30) @map("dm_cache_ttl_days")

  // Org-level identity (independent of members)
  identity_commitment String? @unique @map("identity_commitment")
  wallet_address      String? @unique @map("wallet_address")
  wallet_type         String? @map("wallet_type")

  // Country (ISO 3166-1 alpha-2) — primary operating country
  countryCode String @default("US") @map("country_code")

  // Public profile (org discovery)
  mission    String?
  websiteUrl String? @map("website_url")
  logoUrl    String? @map("logo_url")
  isPublic   Boolean @default(false) @map("is_public")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  memberships       OrgMembership[]
  templates         Template[]            @relation("OrgTemplates")
  endorsements      TemplateEndorsement[]
  resolved_contacts OrgResolvedContact[]
  invites           OrgInvite[]
  subscription      Subscription?
  supporters        Supporter[]
  campaigns         Campaign[]
  tags              Tag[]
  blasts            EmailBlast[]
  anSyncs           AnSync[]
  apiKeys           ApiKey[]
  segments          Segment[]
  events            Event[]
  donations         Donation[]
  workflows         Workflow[]
  smsBlasts         SmsBlast[]
  patchThroughCalls PatchThroughCall[]

  ownedNetworks      OrgNetwork[]       @relation("NetworkOwner")
  networkMemberships OrgNetworkMember[]

  // Intelligence loop
  issueDomains   OrgIssueDomain[]
  billRelevances OrgBillRelevance[]
  alerts         LegislativeAlert[]
  receipts       AccountabilityReceipt[]
  dmFollows      OrgDMFollow[]
  billWatches    OrgBillWatch[]

  @@map("organization")
}

model OrgMembership {
  id     String @id @default(cuid())
  userId String @map("user_id")
  orgId  String @map("org_id")

  role      String   @default("member") // 'owner' | 'editor' | 'member'
  joinedAt  DateTime @default(now()) @map("joined_at")
  invitedBy String?  @map("invited_by")

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
  @@index([orgId])
  @@map("org_membership")
}

model OrgInvite {
  id    String @id @default(cuid())
  orgId String @map("org_id")

  role      String   @default("member")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  accepted  Boolean  @default(false)
  invitedBy String   @map("invited_by")

  // PII encryption at rest (scrubbed Cycle 6)
  encrypted_email String  @map("encrypted_email") // AES-256-GCM JSON { ciphertext, iv }
  email_hash      String  @map("email_hash")      // HMAC-SHA256 for hash-based lookups

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([email_hash])
  @@map("org_invite")
}

model OrgResolvedContact {
  id    String @id @default(cuid())
  orgId String @map("org_id")

  orgKey      String  @map("org_key")
  name        String
  title       String
  email       String
  emailSource String? @map("email_source")

  resolvedAt DateTime @default(now()) @map("resolved_at")
  expiresAt  DateTime @map("expires_at")
  resolvedBy String?  @map("resolved_by")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, orgKey, title])
  @@index([orgId])
  @@index([expiresAt])
  @@map("org_resolved_contact")
}

// Coalition networks: parent/child org relationships for shared supporter pools
model OrgNetwork {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?
  ownerOrgId  String  @map("owner_org_id")
  status      String  @default("active") // 'active' | 'suspended'

  // Cross-border: ISO 3166-1 alpha-2 codes. Empty = unrestricted.
  applicableCountries String[] @default([]) @map("applicable_countries")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  ownerOrg Organization       @relation("NetworkOwner", fields: [ownerOrgId], references: [id], onDelete: Cascade)
  members  OrgNetworkMember[]

  @@index([ownerOrgId])
  @@map("org_network")
}

model OrgNetworkMember {
  id        String   @id @default(cuid())
  networkId String   @map("network_id")
  orgId     String   @map("org_id")
  role      String   @default("member") // 'admin' | 'member'
  status    String   @default("active") // 'active' | 'pending' | 'removed'
  joinedAt  DateTime @default(now()) @map("joined_at")
  invitedBy String?  @map("invited_by")

  network OrgNetwork   @relation(fields: [networkId], references: [id], onDelete: Cascade)
  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([networkId, orgId])
  @@index([networkId])
  @@index([orgId])
  @@map("org_network_member")
}

// Coalition endorsement: multiple orgs can endorse the same template
// Per DESIGN-004-COALITION-COORDINATION.md §2.3
model TemplateEndorsement {
  id         String   @id @default(cuid())
  templateId String   @map("template_id")
  orgId      String   @map("org_id")
  endorsedAt DateTime @default(now()) @map("endorsed_at")
  endorsedBy String?  @map("endorsed_by") // userId of the person who endorsed

  template Template     @relation(fields: [templateId], references: [id], onDelete: Cascade)
  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([templateId, orgId])
  @@index([templateId])
  @@index([orgId])
  @@map("template_endorsement")
}

model Supporter {
  id    String @id @default(cuid())
  orgId String @map("org_id")

  name       String?
  postalCode String? @map("postal_code")
  country    String? @default("US")
  phone      String?

  // PII encryption at rest (scrubbed Cycle 6)
  encrypted_email String  @map("encrypted_email") // AES-256-GCM JSON { ciphertext, iv }
  email_hash      String  @map("email_hash") // HMAC-SHA256 for dedup lookups

  // ZK identity binding (links to protocol layer without revealing credential)
  identityCommitment String? @map("identity_commitment")

  // Verification state: imported → postal-resolved → verified
  verified    Boolean @default(false)
  emailStatus String  @default("subscribed") @map("email_status") // subscribed|unsubscribed|bounced|complained
  smsStatus   String  @default("none") @map("sms_status") // none|subscribed|unsubscribed|stopped

  // Import tracking
  source     String?   @map("source") // 'csv' | 'action_network' | 'organic' | 'widget'
  importedAt DateTime? @map("imported_at")

  // Flexible data
  customFields Json? @map("custom_fields")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org                Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tags               SupporterTag[]
  actions            CampaignAction[]
  rsvps              EventRsvp[]
  donations          Donation[]
  workflowExecutions WorkflowExecution[]
  smsMessages        SmsMessage[]
  patchThroughCalls  PatchThroughCall[]

  @@unique([orgId, email_hash])
  @@index([orgId])
  @@index([emailStatus])
  @@index([smsStatus])
  @@index([source])
  @@index([identityCommitment])
  @@map("supporter")
}

model Tag {
  id    String @id @default(cuid())
  orgId String @map("org_id")
  name  String

  org        Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  supporters SupporterTag[]

  @@unique([orgId, name])
  @@index([orgId])
  @@map("tag")
}

model SupporterTag {
  id          String @id @default(cuid())
  supporterId String @map("supporter_id")
  tagId       String @map("tag_id")

  supporter Supporter @relation(fields: [supporterId], references: [id], onDelete: Cascade)
  tag       Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([supporterId, tagId])
  @@map("supporter_tag")
}

model Segment {
  id          String  @id @default(cuid())
  orgId       String  @map("org_id")
  name        String
  description String?

  // JSON filter definition (SegmentFilter type)
  filters Json // { logic: 'AND'|'OR', conditions: SegmentCondition[] }

  // Cached count (refreshed on access if stale > 5 min)
  cachedCount Int?      @map("cached_count")
  countedAt   DateTime? @map("counted_at")

  createdBy String   @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [createdBy], references: [id])

  @@unique([orgId, name])
  @@index([orgId])
  @@map("segment")
}

model Campaign {
  id    String @id @default(cuid())
  orgId String @map("org_id")

  type   String // 'LETTER' | 'EVENT' | 'FORM'
  title  String
  body   String?
  status String  @default("DRAFT") // 'DRAFT' | 'ACTIVE' | 'PAUSED' | 'COMPLETE'

  // Target resolution
  targets Json? // Resolved decision-maker targets

  // Template linkage (dual ownership via Template.orgId)
  templateId String? @map("template_id")

  // Debate market
  debateEnabled   Boolean @default(false) @map("debate_enabled")
  debateThreshold Int     @default(50) @map("debate_threshold")
  debateId        String? @unique @map("debate_id")

  // Fundraising
  goalAmountCents   Int?    @map("goal_amount_cents")
  raisedAmountCents Int     @default(0) @map("raised_amount_cents")
  donorCount        Int     @default(0) @map("donor_count")
  donationCurrency  String? @default("usd") @map("donation_currency")

  // Geographic targeting (Phase 2 Wave 5)
  targetJurisdiction String? @map("target_jurisdiction") // null = congressional (default)
  targetCountry      String  @default("US") @map("target_country")

  // Intelligence loop (bill linkage + org position)
  billId   String? @map("bill_id") // nullable — not all campaigns are bill-triggered
  position String? // "support" | "oppose" | null — required for scorecard alignment

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org               Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  debate            Debate?            @relation(fields: [debateId], references: [id])
  bill              Bill?              @relation(fields: [billId], references: [id])
  actions           CampaignAction[]
  deliveries        CampaignDelivery[]
  events            Event[]
  donations         Donation[]
  smsBlasts         SmsBlast[]
  patchThroughCalls PatchThroughCall[]

  @@index([orgId])
  @@index([status])
  @@map("campaign")
}

model CampaignAction {
  id          String  @id @default(cuid())
  campaignId  String  @map("campaign_id")
  supporterId String? @map("supporter_id")

  verified       Boolean @default(false)
  engagementTier Int     @default(0) @map("engagement_tier") // 0=New, 1=Active, 2=Established, 3=Veteran, 4=Pillar
  districtHash   String? @map("district_hash") // SHA-256(district) for geographic aggregate
  messageHash    String? @map("message_hash") // SHA-256(message) for ALD uniqueness

  // Agentic delegation flag (Phase A)
  delegated         Boolean  @default(false)
  delegationGrantId String?  @map("delegation_grant_id")

  sentAt    DateTime @default(now()) @map("sent_at")
  createdAt DateTime @default(now()) @map("created_at")

  campaign  Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  supporter Supporter? @relation(fields: [supporterId], references: [id], onDelete: SetNull)

  @@index([campaignId])
  @@index([campaignId, verified])
  @@index([campaignId, districtHash])
  @@map("campaign_action")
}

model CampaignDelivery {
  id             String  @id @default(cuid())
  campaignId     String  @map("campaign_id")
  targetEmail    String  @map("target_email")
  targetName     String? @map("target_name")
  targetTitle    String? @map("target_title")
  targetDistrict String? @map("target_district")

  status String    @default("queued") // queued | sent | delivered | bounced | opened
  sentAt DateTime? @map("sent_at")

  // SES event correlation
  sesMessageId String? @map("ses_message_id") // SES MessageId for SNS event correlation

  // Frozen verification packet at send time
  packetSnapshot Json @map("packet_snapshot")

  // Precomputed at delivery time for receipt generation
  packetDigest   String? @map("packet_digest")
  proofWeight    Float?  @map("proof_weight")

  createdAt DateTime @default(now()) @map("created_at")

  campaign  Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  responses ReportResponse[]

  @@index([campaignId])
  @@index([campaignId, status])
  @@map("campaign_delivery")
}

model EmailBlast {
  id         String  @id @default(cuid())
  orgId      String  @map("org_id")
  campaignId String? @map("campaign_id") // optional campaign linkage

  subject   String
  bodyHtml  String @map("body_html")
  fromName  String @map("from_name")
  fromEmail String @map("from_email")

  status String @default("draft") // draft | sending | sent | failed

  // Recipient targeting
  recipientFilter Json? @map("recipient_filter") // tag/verification/tier filters
  totalRecipients Int   @default(0) @map("total_recipients")

  // Verification context (computed at send time, injected into every email)
  verificationContext Json? @map("verification_context")

  // Aggregate metrics
  totalSent       Int @default(0) @map("total_sent")
  totalBounced    Int @default(0) @map("total_bounced")
  totalOpened     Int @default(0) @map("total_opened")
  totalClicked    Int @default(0) @map("total_clicked")
  totalComplained Int @default(0) @map("total_complained")

  sentAt    DateTime? @map("sent_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  // A/B testing
  isAbTest         Boolean   @default(false) @map("is_ab_test")
  abTestConfig     Json?     @map("ab_test_config") // { splitPct, winnerMetric, testDurationMs, testGroupPct }
  abVariant        String?   @map("ab_variant") // 'A' | 'B' | null (winner send)
  abParentId       String?   @map("ab_parent_id") // Correlation ID linking A/B/winner blasts
  abWinnerPickedAt DateTime? @map("ab_winner_picked_at")

  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  batches EmailBatch[]
  events  EmailEvent[]

  @@index([orgId])
  @@index([status])
  @@index([abParentId])
  @@map("email_blast")
}

model EmailBatch {
  id         String @id @default(cuid())
  blastId    String @map("blast_id")
  batchIndex Int    @map("batch_index")

  status      String    @default("pending") // pending | sending | sent | failed
  sentCount   Int       @default(0) @map("sent_count")
  failedCount Int       @default(0) @map("failed_count")
  error       String?
  sentAt      DateTime? @map("sent_at")

  blast EmailBlast @relation(fields: [blastId], references: [id], onDelete: Cascade)

  @@index([blastId])
  @@map("email_batch")
}

model EmailEvent {
  id      String @id @default(cuid())
  blastId String @map("blast_id")

  recipientEmail String @map("recipient_email")
  eventType      String @map("event_type") // 'open' | 'click' | 'bounce' | 'complaint'

  // Click-specific
  linkUrl   String? @map("link_url")
  linkIndex Int?    @map("link_index")

  timestamp DateTime @default(now())

  blast EmailBlast @relation(fields: [blastId], references: [id], onDelete: Cascade)

  @@index([blastId])
  @@index([blastId, eventType])
  @@index([recipientEmail])
  @@map("email_event")
}

model AnSync {
  id    String @id @default(cuid())
  orgId String @map("org_id")

  apiKey   String @map("api_key") // encrypted AN OSDI-API-Token
  status   String @default("idle") // idle | running | completed | failed
  syncType String @map("sync_type") // 'full' | 'incremental'

  // Progress tracking
  totalResources     Int     @default(0) @map("total_resources")
  processedResources Int     @default(0) @map("processed_resources")
  currentResource    String? @map("current_resource") // 'people' | 'petitions' | 'events' etc.

  // Results
  imported Int   @default(0)
  updated  Int   @default(0)
  skipped  Int   @default(0)
  errors   Json? // array of error strings

  lastSyncAt  DateTime? @map("last_sync_at")
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([status])
  @@map("an_sync")
}

model Subscription {
  id String @id @default(cuid())

  // Polymorphic owner
  userId String? @unique @map("user_id")
  orgId  String? @unique @map("org_id")

  plan             String  @default("pro") // 'pro' | 'org'
  plan_description String? @map("plan_description")
  price_cents      Int     @default(0) @map("price_cents")

  status               String   @default("active") @map("status") // 'active' | 'past_due' | 'canceled' | 'trialing'
  current_period_start DateTime @map("current_period_start")
  current_period_end   DateTime @map("current_period_end")

  // Payment method
  payment_method String @default("stripe") @map("payment_method") // 'stripe' | 'crypto'

  // Stripe
  stripe_subscription_id String? @unique @map("stripe_subscription_id")

  // Crypto
  paying_address   String?   @map("paying_address")
  payment_chain    String?   @map("payment_chain")
  payment_token    String?   @map("payment_token")
  last_tx_hash     String?   @map("last_tx_hash")
  last_verified_at DateTime? @map("last_verified_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org  Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("subscription")
}

model ApiKey {
  id    String @id @default(cuid())
  orgId String @map("org_id")

  // SHA-256 hash of the key (plaintext never stored)
  keyHash   String @unique @map("key_hash")
  // First 8 chars of plaintext for display ("ck_live_a1b2c3d4...")
  keyPrefix String @map("key_prefix")

  name   String   @default("Default")
  scopes String[] @default(["read"]) // 'read' | 'write'

  // Usage tracking
  lastUsedAt   DateTime? @map("last_used_at")
  requestCount Int       @default(0) @map("request_count")

  // Lifecycle
  revokedAt DateTime? @map("revoked_at")
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  createdBy String?   @map("created_by") // userId who created it

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([keyHash])
  @@map("api_key")
}

// ── Events (Phase 2 Wave 1) ──

enum EventType {
  IN_PERSON
  VIRTUAL
  HYBRID
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum RsvpStatus {
  GOING
  MAYBE
  NOT_GOING
  WAITLISTED
}

model Event {
  id         String  @id @default(cuid())
  orgId      String  @map("org_id")
  campaignId String? @map("campaign_id")

  title       String
  description String?   @db.Text
  eventType   EventType @default(IN_PERSON) @map("event_type")

  // When
  startAt  DateTime  @map("start_at")
  endAt    DateTime? @map("end_at")
  timezone String    @default("America/New_York")

  // Where (physical)
  venue      String?
  address    String?
  city       String?
  state      String?
  postalCode String? @map("postal_code")
  latitude   Float?
  longitude  Float?

  // Where (virtual)
  virtualUrl String? @map("virtual_url")

  // Capacity
  capacity        Int?
  waitlistEnabled Boolean @default(false) @map("waitlist_enabled")

  // Aggregate counters (denormalized for read performance)
  rsvpCount         Int @default(0) @map("rsvp_count")
  attendeeCount     Int @default(0) @map("attendee_count")
  verifiedAttendees Int @default(0) @map("verified_attendees")

  // Verification
  checkinCode         String? @unique @map("checkin_code")
  requireVerification Boolean @default(false) @map("require_verification")

  status EventStatus @default(DRAFT)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org         Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  campaign    Campaign?         @relation(fields: [campaignId], references: [id])
  rsvps       EventRsvp[]
  attendances EventAttendance[]

  @@index([orgId])
  @@index([orgId, status])
  @@index([startAt])
  @@map("event")
}

model EventRsvp {
  id          String  @id @default(cuid())
  eventId     String  @map("event_id")
  supporterId String? @map("supporter_id")

  encrypted_email String
  email_hash      String
  name            String
  status          RsvpStatus @default(GOING)
  guestCount      Int        @default(0) @map("guest_count")

  // Verification context
  districtHash   String? @map("district_hash")
  engagementTier Int     @default(0) @map("engagement_tier")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  event      Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  supporter  Supporter?       @relation(fields: [supporterId], references: [id], onDelete: SetNull)
  attendance EventAttendance?

  @@unique([eventId, email_hash])
  @@index([eventId])
  @@index([eventId, status])
  @@map("event_rsvp")
}

model EventAttendance {
  id      String  @id @default(cuid())
  eventId String  @map("event_id")
  rsvpId  String? @unique @map("rsvp_id")

  verified           Boolean @default(false)
  verificationMethod String? @map("verification_method") // 'mdl' | 'passkey' | 'checkin_code'
  identityCommitment String? @map("identity_commitment")
  districtHash       String? @map("district_hash")

  checkedInAt DateTime @default(now()) @map("checked_in_at")

  event Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  rsvp  EventRsvp? @relation(fields: [rsvpId], references: [id], onDelete: SetNull)

  @@index([eventId])
  @@map("event_attendance")
}

// ── Fundraising (Phase 2 Wave 2) ──

model Donation {
  id          String  @id @default(cuid())
  orgId       String  @map("org_id")
  campaignId  String  @map("campaign_id")
  supporterId String? @map("supporter_id")

  email String
  name  String

  amountCents       Int     @map("amount_cents")
  currency          String  @default("usd")
  recurring         Boolean @default(false)
  recurringInterval String? @map("recurring_interval") // 'month' | 'year'

  stripeSessionId       String? @unique @map("stripe_session_id")
  stripePaymentIntentId String? @unique @map("stripe_payment_intent_id")
  stripeSubscriptionId  String? @map("stripe_subscription_id")

  status String @default("pending") // 'pending' | 'completed' | 'failed' | 'refunded'

  districtHash   String? @map("district_hash")
  engagementTier Int     @default(0) @map("engagement_tier")

  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  campaign  Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  supporter Supporter?   @relation(fields: [supporterId], references: [id], onDelete: SetNull)

  @@index([orgId])
  @@index([campaignId])
  @@index([supporterId])
  @@index([status])
  @@map("donations")
}

// ── Automation (Phase 2 Wave 3) ──

model Workflow {
  id          String  @id @default(cuid())
  orgId       String  @map("org_id")
  name        String
  description String?

  trigger Json // { type: 'donation_completed' | 'event_rsvp' | 'event_checkin' | 'campaign_action' | 'supporter_created' | 'tag_added', ... }
  steps   Json // Array of step objects

  enabled Boolean @default(false)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org        Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  executions WorkflowExecution[]

  @@index([orgId])
  @@index([enabled])
  @@map("workflows")
}

model WorkflowExecution {
  id          String  @id @default(cuid())
  workflowId  String  @map("workflow_id")
  supporterId String? @map("supporter_id")

  triggerEvent Json @map("trigger_event") // snapshot of what triggered: { type, entityId, ... }

  status      String    @default("pending") // 'pending' | 'running' | 'completed' | 'failed' | 'paused'
  currentStep Int       @default(0) @map("current_step")
  nextRunAt   DateTime? @map("next_run_at")
  error       String?

  createdAt   DateTime  @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")

  workflow   Workflow            @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  supporter  Supporter?          @relation(fields: [supporterId], references: [id], onDelete: SetNull)
  actionLogs WorkflowActionLog[]

  @@index([workflowId])
  @@index([supporterId])
  @@index([status])
  @@index([nextRunAt])
  @@map("workflow_executions")
}

model WorkflowActionLog {
  id          String @id @default(cuid())
  executionId String @map("execution_id")

  stepIndex  Int    @map("step_index")
  actionType String @map("action_type") // 'send_email' | 'add_tag' | 'remove_tag' | 'delay' | 'condition'
  result     Json?

  createdAt DateTime @default(now()) @map("created_at")

  execution WorkflowExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId])
  @@map("workflow_action_logs")
}

// ── SMS + Patch-through Calling (Phase 2 Wave 4) ──

model SmsBlast {
  id         String  @id @default(cuid())
  orgId      String  @map("org_id")
  campaignId String? @map("campaign_id")

  body       String
  fromNumber String @map("from_number")

  recipientFilter Json? @map("recipient_filter")
  totalRecipients Int   @default(0) @map("total_recipients")

  sentCount      Int @default(0) @map("sent_count")
  deliveredCount Int @default(0) @map("delivered_count")
  failedCount    Int @default(0) @map("failed_count")

  status String @default("draft")

  sentAt    DateTime? @map("sent_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  campaign Campaign?    @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  messages SmsMessage[]

  @@index([orgId])
  @@index([status])
  @@map("sms_blasts")
}

model SmsMessage {
  id          String @id @default(cuid())
  blastId     String @map("blast_id")
  supporterId String @map("supporter_id")

  to   String
  body String

  twilioSid String? @map("twilio_sid")
  status    String  @default("queued")
  errorCode String? @map("error_code")

  createdAt DateTime @default(now()) @map("created_at")

  blast     SmsBlast  @relation(fields: [blastId], references: [id], onDelete: Cascade)
  supporter Supporter @relation(fields: [supporterId], references: [id], onDelete: Cascade)

  @@index([blastId])
  @@index([supporterId])
  @@index([twilioSid])
  @@map("sms_messages")
}

model PatchThroughCall {
  id          String  @id @default(cuid())
  orgId       String  @map("org_id")
  campaignId  String? @map("campaign_id")
  supporterId String  @map("supporter_id")

  callerPhone String  @map("caller_phone")
  targetPhone String  @map("target_phone")
  targetName  String? @map("target_name")
  targetTitle String? @map("target_title")

  twilioCallSid String? @unique @map("twilio_call_sid")
  districtHash  String? @map("district_hash")

  status   String @default("initiated")
  duration Int?

  createdAt   DateTime  @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  campaign  Campaign?    @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  supporter Supporter    @relation(fields: [supporterId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([campaignId])
  @@index([supporterId])
  @@index([status])
  @@map("patch_through_calls")
}

// ── International Geographic Expansion (Phase 2 Wave 5) ──
// InternationalRepresentative removed — subsumed by DecisionMaker + ExternalId

model ScopeCorrection {
  id         String @id @default(cuid())
  templateId String @map("template_id")

  aiExtracted  Json   @map("ai_extracted")
  aiConfidence Float  @map("ai_confidence")
  aiMethod     String @map("ai_method") // 'regex' | 'fuzzy' | 'geocoder' | 'llm'

  userCorrected  Json   @map("user_corrected")
  correctionType String @map("correction_type") // 'wrong_country' | 'wrong_region' | 'wrong_district' | 'too_broad' | 'too_specific'

  messageSnippet String @map("message_snippet")
  subject        String

  createdAt DateTime @default(now()) @map("created_at")

  @@index([aiMethod, correctionType])
  @@index([createdAt])
  @@map("scope_corrections")
}

// ============================================================================
// Intelligence Loop: Legislative Monitoring & Scorecards
// ============================================================================

// Bill / legislative item tracked by the intelligence loop
model Bill {
  id                String   @id @default(cuid())
  externalId        String   @unique @map("external_id") // e.g. "hr-1234-119" or "ca-sb-567-2026"
  jurisdiction      String // "us-federal" | "us-state-ca" | "uk-parliament" | etc.
  jurisdictionLevel String   @map("jurisdiction_level") // "federal" | "state" | "local"
  chamber           String? // "house" | "senate" | "council" | null
  title             String
  summary           String?
  status            String   @default("introduced") // introduced | committee | floor | passed | failed | signed | vetoed
  statusDate        DateTime @map("status_date")
  sponsors          Json? // [{name, externalId, party}]
  committees        String[] // committee names
  sourceUrl         String   @map("source_url")
  fullTextUrl       String?  @map("full_text_url")

  // Relevance scoring (computed per-org via OrgBillRelevance)
  topicEmbedding Unsupported("vector(768)")? @map("topic_embedding")
  topics         String[]
  entities       String[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  campaigns  Campaign[]
  alerts     LegislativeAlert[]
  relevances OrgBillRelevance[]
  actions    LegislativeAction[]
  receipts   AccountabilityReceipt[]
  watchers   OrgBillWatch[]

  // Note: bill.fts tsvector column added via raw SQL in migration:
  // ALTER TABLE "bill" ADD COLUMN IF NOT EXISTS fts tsvector
  //   GENERATED ALWAYS AS (to_tsvector('english', coalesce(title, '') || ' ' || coalesce(summary, ''))) STORED;
  // CREATE INDEX IF NOT EXISTS bill_fts_gin ON bill USING gin(fts);

  @@index([jurisdiction, status])
  @@index([statusDate])
  @@index([externalId])
  @@map("bill")
}

// Per-org relevance score for a bill (avoids N*M recomputation)
model OrgBillRelevance {
  id        String   @id @default(cuid())
  orgId     String   @map("org_id")
  billId    String   @map("bill_id")
  score     Float // 0.0-1.0 cosine similarity between bill embedding and org issue domains
  matchedOn String[] @map("matched_on") // which org topics matched

  createdAt DateTime @default(now()) @map("created_at")

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  bill Bill         @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@unique([orgId, billId])
  @@index([orgId, score])
  @@map("org_bill_relevance")
}

// Alert generated when a bill is relevant to an org
model LegislativeAlert {
  id          String  @id @default(cuid())
  orgId       String  @map("org_id")
  billId      String  @map("bill_id")
  type        String // "new_bill" | "status_change" | "vote_scheduled" | "amendment"
  title       String
  summary     String
  urgency     String  @default("normal") // "low" | "normal" | "high" | "critical"
  status      String  @default("pending") // "pending" | "seen" | "acted" | "dismissed"
  actionTaken String? @map("action_taken") // "created_campaign" | "sent_email" | null

  createdAt DateTime  @default(now()) @map("created_at")
  seenAt    DateTime? @map("seen_at")

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  bill Bill         @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@unique([orgId, billId, type])
  @@index([orgId, status])
  @@index([orgId, createdAt])
  @@map("legislative_alert")
}

// Tracks what a decision-maker did after receiving a report
model ReportResponse {
  id         String   @id @default(cuid())
  deliveryId String   @map("delivery_id")
  type       String // "opened" | "clicked_verify" | "replied" | "forwarded" | "meeting_requested" | "vote_cast" | "public_statement"
  detail     String? // free-text: reply excerpt, vote direction, etc.
  confidence String   @default("observed") // "observed" (SES events) | "inferred" (timing correlation) | "reported" (org manually logs)
  occurredAt DateTime @map("occurred_at")
  createdAt  DateTime @default(now()) @map("created_at")

  delivery CampaignDelivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  @@index([deliveryId])
  @@index([occurredAt])
  @@map("report_response")
}

// Decision-maker action on a bill (vote, sponsorship, statement)
model LegislativeAction {
  id              String   @id @default(cuid())
  billId          String   @map("bill_id")
  decisionMakerId String?  @map("decision_maker_id") // nullable: not all officials are in our DB
  externalId      String?  @map("external_id") // bioguide_id, openstates_id, etc.
  name            String
  action          String // "voted_yes" | "voted_no" | "abstained" | "sponsored" | "co-sponsored" | "statement"
  detail          String?
  sourceUrl       String?  @map("source_url")
  occurredAt      DateTime @map("occurred_at")
  createdAt       DateTime @default(now()) @map("created_at")

  bill            Bill           @relation(fields: [billId], references: [id], onDelete: Cascade)
  decisionMaker   DecisionMaker? @relation(fields: [decisionMakerId], references: [id])

  @@index([billId])
  @@index([decisionMakerId])
  @@index([occurredAt])
  @@index([decisionMakerId, occurredAt])
  @@map("legislative_action")
}

// Accountability Receipt: proof-weighted decision-maker tracking
model AccountabilityReceipt {
  id                String   @id @default(cuid())

  // Decision-maker (canonical FK)
  decisionMakerId   String   @map("decision_maker_id")
  dmName            String   @map("dm_name")

  // Bill
  billId            String   @map("bill_id")

  // Org that delivered the proof
  orgId             String   @map("org_id")

  // Specific delivery (nullable for aggregate receipts)
  deliveryId        String?  @unique @map("delivery_id")

  // Proof weight components (frozen from packetSnapshot)
  verifiedCount     Int      @map("verified_count")
  totalCount        Int      @map("total_count")
  gds               Float?
  ald               Float?
  cai               Float?
  temporalEntropy   Float?   @map("temporal_entropy")
  districtCount     Int      @map("district_count")
  proofWeight       Float    @map("proof_weight")

  // Cryptographic binding (SHA-256 hot path; Poseidon2 at anchor time)
  attestationDigest String   @map("attestation_digest")
  packetDigest      String   @map("packet_digest")

  // Temporal chain
  proofDeliveredAt  DateTime @map("proof_delivered_at")
  proofVerifiedAt   DateTime? @map("proof_verified_at")
  actionOccurredAt  DateTime? @map("action_occurred_at")
  causalityClass    String   @default("pending") @map("causality_class")

  // Decision-maker action
  dmAction          String?  @map("dm_action")
  alignment         Float    @default(0)
  actionSourceUrl   String?  @map("action_source_url")

  // Anchoring (set by Phase 4 anchoring script)
  anchorCid         String?  @map("anchor_cid")
  anchorRoot        String?  @map("anchor_root")

  // Metadata
  status            String   @default("pending")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // Relations
  decisionMaker     DecisionMaker @relation(fields: [decisionMakerId], references: [id])
  bill              Bill          @relation(fields: [billId], references: [id], onDelete: Cascade)
  org               Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, billId, decisionMakerId])
  @@index([decisionMakerId])
  @@index([decisionMakerId, proofDeliveredAt])
  @@index([billId])
  @@index([orgId])
  @@index([status])
  @@index([causalityClass])
  @@map("accountability_receipt")
}

// Org's declared issue domains (used for bill relevance scoring)
model OrgIssueDomain {
  id          String                      @id @default(cuid())
  orgId       String                      @map("org_id")
  label       String // "water rights", "school safety", "transit equity"
  embedding   Unsupported("vector(768)")? // precomputed from label + description
  description String?
  weight      Float                       @default(1.0) // org can prioritize domains

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, label])
  @@index([orgId])
  @@map("org_issue_domain")
}

// ============================================================================
// Decision Maker: Universal accountability target
// ============================================================================

model DecisionMaker {
	id                String    @id @default(cuid())
	type              String    // "legislator" | "executive" | "board_member" | "appointed_official" | "corporate_officer" | "administrator" | "judicial" | "custom"
	title             String?   // "Senator", "CEO", "Commissioner", "Board Member"
	name              String
	firstName         String?   @map("first_name")
	lastName          String    @map("last_name")
	party             String?
	jurisdiction      String?   // geographic scope: "US", "California", "Austin, TX", "UK"
	jurisdictionLevel String?   @map("jurisdiction_level") // "federal" | "state" | "county" | "municipal" | "international" | "private"
	district          String?   // constituency/ward/district within jurisdiction
	phone             String?
	email             String?
	websiteUrl        String?   @map("website_url")
	officeAddress     String?   @map("office_address")
	photoUrl          String?   @map("photo_url")
	active            Boolean   @default(true)
	termStart         DateTime? @map("term_start")
	termEnd           DateTime? @map("term_end")
	lastSyncedAt      DateTime? @map("last_synced_at")
	createdAt         DateTime  @default(now()) @map("created_at")
	updatedAt         DateTime  @updatedAt @map("updated_at")

	institutionId     String?   @map("institution_id")
	institution       Institution? @relation(fields: [institutionId], references: [id])

	externalIds       ExternalId[]
	actions           LegislativeAction[]
	receipts          AccountabilityReceipt[]
	scorecardSnapshots ScorecardSnapshot[]
	followers         OrgDMFollow[]
	userRelations     UserDMRelation[]

	@@index([type])
	@@index([jurisdiction, jurisdictionLevel])
	@@index([party])
	@@index([lastName])
	@@index([institutionId])
	@@index([active])
	@@map("decision_maker")
}

model Institution {
	id                String    @id @default(cuid())
	type              String    // "legislature" | "executive_branch" | "agency" | "corporation" | "university" | "nonprofit" | "judicial" | "international_body" | "municipal_body"
	name              String
	jurisdiction      String?
	jurisdictionLevel String?   @map("jurisdiction_level")
	parentId          String?   @map("parent_id")
	websiteUrl        String?   @map("website_url")
	createdAt         DateTime  @default(now()) @map("created_at")
	updatedAt         DateTime  @updatedAt @map("updated_at")

	parent            Institution?  @relation("InstitutionHierarchy", fields: [parentId], references: [id])
	children          Institution[] @relation("InstitutionHierarchy")
	members           DecisionMaker[]

	@@unique([type, name, jurisdiction])
	@@index([type])
	@@index([jurisdictionLevel])
	@@index([parentId])
	@@map("institution")
}

model ExternalId {
	id              String   @id @default(cuid())
	decisionMakerId String   @map("decision_maker_id")
	system          String   // "bioguide" | "openstates" | "wikidata" | "linkedin" | "fec" | "votesmart" | "icma" | "constituency" | "manual"
	value           String
	createdAt       DateTime @default(now()) @map("created_at")

	decisionMaker   DecisionMaker @relation(fields: [decisionMakerId], references: [id], onDelete: Cascade)

	@@unique([decisionMakerId, system])
	@@unique([system, value])
	@@index([system, value])
	@@map("external_id")
}

model OrgDMFollow {
	id              String   @id @default(cuid())
	orgId           String   @map("org_id")
	decisionMakerId String   @map("decision_maker_id")
	reason          String   @default("manual")
	alertsEnabled   Boolean  @default(true) @map("alerts_enabled")
	note            String?
	followedBy      String?  @map("followed_by")
	followedAt      DateTime @default(now()) @map("followed_at")

	org             Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
	decisionMaker   DecisionMaker @relation(fields: [decisionMakerId], references: [id], onDelete: Cascade)

	@@unique([orgId, decisionMakerId])
	@@index([orgId])
	@@index([decisionMakerId])
	@@map("org_dm_follow")
}

// Org watches a bill for manual tracking / watchlist
model OrgBillWatch {
  id        String   @id @default(cuid())
  orgId     String   @map("org_id")
  billId    String   @map("bill_id")
  reason    String   @default("manual") // "manual" | "alert" | "campaign"
  position  String?  // "support" | "oppose" | null
  addedBy   String?  @map("added_by")
  createdAt DateTime @default(now()) @map("created_at")

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  bill      Bill         @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@unique([orgId, billId])
  @@index([orgId])
  @@map("org_bill_watch")
}

// ============================================================================
// Scorecard: Periodic legislator accountability snapshots
// ============================================================================

model ScorecardSnapshot {
  id                 String   @id @default(cuid())
  decisionMakerId    String   @map("decision_maker_id")

  // Period
  periodStart        DateTime @map("period_start")
  periodEnd          DateTime @map("period_end")

  // Scores
  responsiveness     Float?   // 0-100, null if insufficient data
  alignment          Float?   // 0-100, null if insufficient data
  composite          Float?   // 0-100, null if either component null
  proofWeightTotal   Float    @map("proof_weight_total")

  // Input counts (for transparency)
  deliveriesSent     Int      @map("deliveries_sent")
  deliveriesOpened   Int      @map("deliveries_opened")
  deliveriesVerified Int      @map("deliveries_verified")
  repliesReceived    Int      @map("replies_received")
  alignedVotes       Int      @map("aligned_votes")
  totalScoredVotes   Int      @map("total_scored_votes")

  // Methodology version (for future algorithm changes)
  methodologyVersion Int      @default(1) @map("methodology_version")

  // Attestation
  snapshotHash       String   @map("snapshot_hash") // SHA-256 of all input data

  createdAt          DateTime @default(now()) @map("created_at")

  decisionMaker      DecisionMaker @relation(fields: [decisionMakerId], references: [id], onDelete: Cascade)

  @@unique([decisionMakerId, periodEnd, methodologyVersion])
  @@index([decisionMakerId])
  @@index([periodEnd])
  @@index([composite])
  @@map("scorecard_snapshot")
}

// ============================================================================
// Agentic Delegation: AI proxy civic actions under user-defined policy
// Phase A: schema + CRUD + policy parsing (execution engine deferred to Phase B)
// ============================================================================

model DelegationGrant {
  id                  String    @id @default(cuid())
  userId              String    @map("user_id")

  // Scope
  scope               String    // 'campaign_sign' | 'debate_position' | 'message_generate' | 'full'

  // Constraints
  issueFilter         String[]  @default([])
  orgFilter           String[]  @default([])
  stanceProfileId     String?   @map("stance_profile_id")
  maxActionsPerDay    Int       @default(5) @map("max_actions_per_day")
  requireReviewAbove  Float     @default(10) @map("require_review_above")

  // Natural language policy (encrypted at rest via PII encryption pattern)
  policyText          String    @map("policy_text")

  // Lifecycle
  expiresAt           DateTime? @map("expires_at")
  revokedAt           DateTime? @map("revoked_at")
  status              String    @default("active") // 'active' | 'paused' | 'revoked' | 'expired'

  // Audit
  lastActionAt        DateTime? @map("last_action_at")
  totalActions        Int       @default(0) @map("total_actions")

  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  actions             DelegatedAction[]
  reviewQueue         DelegationReview[]

  @@index([userId])
  @@index([status])
  @@map("delegation_grant")
}

model DelegatedAction {
  id                String   @id @default(cuid())
  grantId           String   @map("grant_id")

  // What was done
  actionType        String   @map("action_type") // 'campaign_sign' | 'debate_position' | 'message_generate'
  targetId          String   @map("target_id")   // campaignId or debateId
  targetTitle       String   @map("target_title")

  // Decision reasoning
  reasoning         String   // agent's reasoning for this action
  relevanceScore    Float    @map("relevance_score") // how well this matched the policy (0-1)
  stanceAlignment   Float?   @map("stance_alignment") // alignment with user's stance profile (0-1)

  // Result
  resultId          String?  @map("result_id")   // CampaignAction.id or DebateArgument.id
  status            String   @default("completed") // 'completed' | 'reviewed' | 'rejected' | 'failed'

  createdAt         DateTime @default(now()) @map("created_at")

  grant             DelegationGrant @relation(fields: [grantId], references: [id], onDelete: Cascade)

  @@index([grantId])
  @@index([createdAt])
  @@map("delegated_action")
}

model DelegationReview {
  id                String    @id @default(cuid())
  grantId           String    @map("grant_id")
  actionId          String?   @map("action_id")

  // What needs review
  targetId          String    @map("target_id")
  targetTitle       String    @map("target_title")
  reasoning         String
  proofWeight       Float     @map("proof_weight")

  // User decision
  decision          String?   // 'approve' | 'reject' | null (pending)
  decidedAt         DateTime? @map("decided_at")

  createdAt         DateTime  @default(now()) @map("created_at")

  grant             DelegationGrant @relation(fields: [grantId], references: [id], onDelete: Cascade)

  @@index([grantId])
  @@index([decision])
  @@map("delegation_review")
}
