# ============================================================================
# COMMONS ENVIRONMENT CONFIGURATION
# ============================================================================
# Last updated: 2025-01 (Post-Cloudflare Migration)
# This file contains ONLY variables actively used by the codebase.
# See docs/development/quickstart.md for setup instructions.
# ============================================================================


# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================

# JWT Secret (Required)
# Used for email verification tokens and one-time tokens
# Generate with: openssl rand -hex 32
JWT_SECRET=your-jwt-secret-here

# Email Verification Secret (Optional, falls back to JWT_SECRET)
EMAIL_VERIFICATION_SECRET=your-email-verification-secret

# Identity Hash Salt (Required for identity verification)
# CRITICAL: Generate once, NEVER regenerate in production (requires data migration)
# Used for Sybil-resistant identity hashing (one-identity-per-account)
# Generate with: openssl rand -hex 32
IDENTITY_HASH_SALT=your-64-char-hex-salt-here-keep-secret-never-regenerate

# Identity Signing Key (Required for Tier 2 credential issuance)
# Ed25519 private key seed for signing W3C VC DistrictResidencyCredentials
# CRITICAL: Generate once, NEVER regenerate in production (invalidates all issued credentials)
# Generate with: openssl rand -hex 32
IDENTITY_SIGNING_KEY=your-64-char-hex-key-here-keep-secret-never-regenerate

# ── Federation parameters (deployment identity) ──
# These set the deployment-specific identity for issued credentials and JWTs.
# Defaults preserve the commons.email reference deployment behavior; peer
# implementations override these to issue under their own DIDs and origins.

# Issuer DID for W3C Verifiable Credentials (Tier 2 DistrictResidencyCredential).
# Format: did:web:<host>. Default: did:web:commons.email
# Example for a peer deployment: did:web:civic.example.org
ISSUER_DID=did:web:commons.email

# JWT issuer URL for Convex auth bridge. MUST match across:
#   - SvelteKit minter (src/lib/server/convex-jwt.ts)
#   - Convex consumer (convex/auth.config.ts)
#   - Convex tokenIdentifier prefix (convex/authOps.ts)
# Default: https://commons.email
# Set this in BOTH .env (for SvelteKit) AND the Convex dashboard
# (https://dashboard.convex.dev) under environment variables.
# Trailing slash is stripped at runtime to prevent operator-typo drift.
CONVEX_AUTH_ISSUER=https://commons.email

# JWKS key id embedded in minted Convex JWTs and served at
# /.well-known/jwks.json. Default: commons-convex-1.
# Peer implementations may override (e.g. civic-convex-1) so JWTs reflect
# the deployment identity in their kid header.
# CHANGING this value invalidates all active sessions because Convex caches
# JWKS by kid. Coordinate the change with a key rotation if rolling at scale.
CONVEX_JWT_KID=commons-convex-1

# Public Atlas host (Shadow Atlas district boundary distribution).
# PUBLIC_ prefix means this value is exposed to the browser at build time.
# Default: https://atlas.commons.email
# Peer implementations point this at their own R2/IPFS-backed atlas.
# NOTE: this is the BROWSER-side atlas host. CSP connect-src reads this at
# svelte.config.js evaluation time so the configured host isn't blocked.
PUBLIC_ATLAS_HOST=https://atlas.commons.email

# Server-side atlas URL — read by Convex actions for officials lookup
# (convex/submissions.ts) and engagement registration. Distinct env var
# from PUBLIC_ATLAS_HOST because it lives in the Convex runtime, not the
# browser bundle. SET BOTH PUBLIC_ATLAS_HOST AND SHADOW_ATLAS_URL TO THE
# SAME ATLAS HOST for a coherent deployment. Set in the Convex dashboard
# (https://dashboard.convex.dev), not in this file.
# Default: https://atlas.commons.email
# SHADOW_ATLAS_URL=https://atlas.commons.email

# Site origin / public base URL — read by email link builders and OG meta.
# Default: https://commons.email. Peer implementations override.
# PUBLIC_BASE_URL=https://commons.email

# Identity Commitment Salt (Required for identity verification)
# CRITICAL: Generate once, NEVER regenerate in production (invalidates all commitments + nullifiers)
# Used to prevent offline passport enumeration against on-chain nullifiers
# Generate with: openssl rand -hex 32
IDENTITY_COMMITMENT_SALT=your-64-char-hex-salt-here-keep-secret-never-regenerate

# Entropy Encryption Key (Required for identity verification)
# AES-256-GCM key for encrypting user_entropy at rest in the database
# CRITICAL: Generate once, NEVER regenerate in production (breaks re-verification flow)
# Generate with: openssl rand -hex 32
ENTROPY_ENCRYPTION_KEY=your-64-char-hex-key-here-keep-secret-never-regenerate

# IP Hash Salt (Required for fraud detection)
# Used for privacy-preserving IP logging with daily rotation
# Can be regenerated safely (daily rotation built in)
# Generate with: openssl rand -hex 32
IP_HASH_SALT=your-64-char-hex-salt-here-keep-secret-safe-to-regenerate

# Submission Anonymization Salt (Required for privacy-preserving submissions)
# SHA-256(user_id + salt) → pseudonymous_id — breaks link between auth identity and on-chain proofs
# NEVER regenerate in production (breaks pseudonymous_id continuity)
# Generate with: openssl rand -hex 32
SUBMISSION_ANONYMIZATION_SALT=your-64-char-hex-salt-here-keep-secret-never-regenerate
# Convex runtime uses PSEUDONYMOUS_ID_SALT for the same purpose (set in
# Convex dashboard, not here). If cross-table joins between submissions
# (Convex-computed) and positionDeliveries (SvelteKit-computed) are ever
# needed, both salts MUST be identical. No cross-join exists today.

# Cron Job Authentication (Required for scheduled tasks)
# Used to authenticate requests to /api/cron/* endpoints
# Generate with: openssl rand -hex 32
CRON_SECRET=your-cron-secret-here

# Internal API Authentication (Required for /api/internal/* operator probes
# AND Convex→SvelteKit calls — alert, anchor-proof, emit-revocation,
# revocation-root, anchor-incidents, health/empty-tree-root, mdl-readiness).
# 32+ char hex (use `openssl rand -hex 32`). Same secret on Convex env via
# `npx convex env set INTERNAL_API_SECRET ...`.
INTERNAL_API_SECRET=your-internal-api-secret-here

# Optional rotation-window previous secret. SvelteKit's
# `matchInternalSecret` accepts active OR _PREVIOUS so a Convex deploy
# with the new secret can still call SvelteKit's internal endpoints
# during the CF Pages rollout window. Procedure (Convex sender →
# SvelteKit receiver):
#   1. Set INTERNAL_API_SECRET_PREVIOUS = current value on SvelteKit.
#   2. Set INTERNAL_API_SECRET = new value on BOTH SvelteKit and Convex.
#   3. Wait for in-flight cron actions (~hours: longest cron is 1h, plus
#      action runtime).
#   4. Unset _PREVIOUS on SvelteKit.
INTERNAL_API_SECRET_PREVIOUS=

# ── Automation Scheduler ──
# Bearer token for POST /api/automation/process (cron endpoint)
# Generate with: openssl rand -hex 32
AUTOMATION_SECRET=


# ============================================================================
# OAUTH PROVIDERS (Required for social login)
# ============================================================================

# OAuth Redirect Base URL
# Production: https://commons.email
# Development: http://localhost:5173
OAUTH_REDIRECT_BASE_URL=http://localhost:5173

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Facebook OAuth (https://developers.facebook.com/apps)
FACEBOOK_CLIENT_ID=your-facebook-client-id
FACEBOOK_CLIENT_SECRET=your-facebook-client-secret

# Twitter/X OAuth (https://developer.twitter.com/portal)
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-client-secret

# LinkedIn OAuth (https://www.linkedin.com/developers/apps)
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# Discord OAuth (https://discord.com/developers/applications)
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret

# Coinbase OAuth (https://www.coinbase.com/settings/api)
# Highest trust score (90) due to KYC requirements
COINBASE_CLIENT_ID=your-coinbase-client-id
COINBASE_CLIENT_SECRET=your-coinbase-client-secret


# ============================================================================
# AI & MODERATION SERVICES
# ============================================================================

# GROQ API (Llama Guard 4 - Safety Moderation) - PRIMARY
# Get key from: https://console.groq.com/keys
# Used for: Content safety classification (MLCommons S1-S14 hazard taxonomy)
# FREE tier: 14,400 requests/day (~432K/month)
# Civic-critical categories: Elections (S13), Defamation (S5)
GROQ_API_KEY=your-groq-api-key-here

# Gemini API (Quality Assessment + AI Agents)
# Get key from: https://aistudio.google.com/apikey
# Used for: Message writing agent, subject line generation, quality moderation
# FREE tier: Unlimited in Google AI Studio
# Paid tier: $0.10/1M tokens (Flash-Lite)
GEMINI_API_KEY=your-gemini-api-key-here

# Exa Search API (Decision-Maker Person Lookup)
# Get key from: https://dashboard.exa.ai
# Used for: Searching for current holders of institutional positions and their contact info
# FREE tier: 2,000 searches/month
# Paid tier: $5/1k searches + $1/1k pages content
EXA_API_KEY=your-exa-api-key-here

# Voyage AI API (Vector Embeddings for Semantic Search)
# Get key from: https://dash.voyageai.com/
# Used for: Semantic search across intelligence and organizations
# FREE tier: 100M tokens/month for voyage-3-lite
# Paid tier: $0.06/1M tokens for voyage-3 (recommended)
VOYAGE_API_KEY=your-voyage-api-key-here

# (OpenAI removed — embeddings use Gemini gemini-embedding-001)


# ============================================================================
# CONGRESSIONAL INTEGRATION (CWC)
# ============================================================================

# Congress.gov API Key (Required for representative lookups)
# Get key from: https://api.congress.gov/sign-up/
CONGRESS_API_KEY=your-congress-api-key

# District resolution uses Shadow Atlas H3 mapping (no external API key needed)
# Census Bureau geocoding is the fallback (no API key required)

# Senate CWC API (Communicating With Congress)
# Get credentials from congressional office partnership
CWC_API_BASE_URL=https://soapbox.senate.gov/api
CWC_API_KEY=your-cwc-api-key
CWC_CAMPAIGN_ID=commons-2025
# Senate path segment. Defaults to `testing-messages` (sandbox inbox). Flip to
# `messages` for production delivery. Without this flip, real constituent data
# lands in the Senate's test inbox and never reaches the staffer.
CWC_SENATE_PATH_PREFIX=testing-messages

# House CWC Integration (GCP Proxy)
# IMPORTANT: House CWC API requires IP whitelisting from Congress
# Apply at: https://www.house.gov/doing-business-with-the-house/communicating-with-congress-cwc
# Contact: CWCVendors@mail.house.gov
#
# Options for House delivery:
# 1. Direct API (requires whitelisted server IP) - not available in most deployments
# 2. GCP proxy server (requires proxy with whitelisted IP) - configure below
# 3. Contact forms (fallback - not yet implemented)
#
# If not configured, House submissions will FAIL with clear error messages
# (Senate submissions work without proxy - they use CWC_API_KEY above)
GCP_PROXY_URL=http://your-whitelisted-proxy-server:8080
GCP_PROXY_AUTH_TOKEN=your-gcp-proxy-auth-token

# CWC Delivery Agent Configuration
# These identify Commons as the delivery agent to Congress
CWC_DELIVERY_AGENT_ID=COMMONS_PBC
CWC_DELIVERY_AGENT_NAME="Commons PBC"
CWC_DELIVERY_AGENT_CONTACT=hello@commons.email
CWC_DELIVERY_AGENT_ACKNOWLEDGEMENT_EMAIL=noreply@commons.email
CWC_DELIVERY_AGENT_ACK=Y

# CWC Production Toggle (Optional, default: sandbox mode)
# When 'true': sends to /messages/ (real Senate endpoint — messages are delivered)
# When unset or 'false': sends to /testing-messages/ (sandbox — messages are not delivered)
# IMPORTANT: Do NOT set to 'true' in development — it will send real messages to Congress
CWC_PRODUCTION=false

# ============ Witness Encryption ============
# X25519 keypair for encrypting/decrypting witness data (address + proof inputs)
# Generate with: npx tsx scripts/generate-witness-keypair.ts
WITNESS_ENCRYPTION_PUBLIC_KEY=0x_generate_with_script
WITNESS_ENCRYPTION_PRIVATE_KEY=0x_generate_with_script


# ============================================================================
# AI DEBATE EVALUATION (Phase 3: AI-Augmented Resolution)
# ============================================================================
# 5-model panel for debate argument evaluation.
# Each model requires a dedicated EIP-712 signing key.
#
# Two modes for LLM API access:
#
# OPTION A — OpenRouter (RECOMMENDED): One API key routes to all 5 models.
#   Set OPENROUTER_API_KEY and leave individual keys unset.
#   Get key from: https://openrouter.ai/keys
#
# OPTION B — Direct: 5 individual API keys (one per provider).
#   Set GOOGLE_AI_API_KEY, DEEPSEEK_API_KEY, etc.
#   OPENROUTER_API_KEY must be unset for direct mode.

# OpenRouter API key (Option A — replaces all 5 individual keys)
OPENROUTER_API_KEY=

# Individual model API keys (Option B — only needed if OPENROUTER_API_KEY is unset)
GOOGLE_AI_API_KEY=your-google-ai-api-key-here
DEEPSEEK_API_KEY=your-deepseek-api-key-here
MISTRAL_API_KEY=your-mistral-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# EIP-712 signing keys for AI evaluation attestation (one per model slot)
# Generate each with: cast wallet new | grep "Private key"
# On testnet (v5): MockAIEvaluationRegistry accepts any signer.
# On production: These wallets must be registered in AIEvaluationRegistry on-chain.
MODEL_SIGNER_KEY_OPENAI=
MODEL_SIGNER_KEY_GOOGLE=
MODEL_SIGNER_KEY_DEEPSEEK=
MODEL_SIGNER_KEY_MISTRAL=
MODEL_SIGNER_KEY_ANTHROPIC=

# Chain ID for EIP-712 domain (534351 = Scroll Sepolia, 534352 = Scroll Mainnet)
CHAIN_ID=534351

# ============================================================================
# TWILIO (SMS + Patch-Through Calling)
# ============================================================================
# Required for FEATURES.SMS. Get credentials at console.twilio.com

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=    # E.164 format, e.g. +15551234567


# ============================================================================
# VOTER PROTOCOL INTEGRATION
# ============================================================================

# Shadow Atlas runtime API (registration + engagement + cell proofs).
# District boundaries are no longer fetched from this server — they're
# served as static GeoJSON bundles from atlas.commons.email/source/...
# (see ATLAS_BASE_URL below). This URL is only consulted by handlers that
# write (registration leaf insertion) or compute (TEE address resolution).
# Development: http://localhost:3000 (docker compose up shadow-atlas)
# Production: not yet deployed — shadow-atlas.commons.email is reserved.
SHADOW_ATLAS_API_URL=http://localhost:3000

# Shadow Atlas registration auth token
# Must match REGISTRATION_AUTH_TOKEN on the shadow-atlas server
# Generate with: openssl rand -hex 32
SHADOW_ATLAS_REGISTRATION_TOKEN=

# Shadow Atlas content sources (updated quarterly)
# R2 custom domain — primary production reads (no CID in path)
ATLAS_BASE_URL=https://atlas.commons.email
VITE_ATLAS_BASE_URL=https://atlas.commons.email

# IPFS (optional — activates content-addressed source layer when ecosystem matures)
# Set both CID + gateways to enable IPFS as a secondary source behind R2.
IPFS_CID_ROOT=
VITE_IPFS_CID_ROOT=
IPFS_CID_MERKLE_SNAPSHOT=
IPFS_GATEWAYS=

# Write relay for Shadow Atlas registration/engagement tree writes
# Defaults to SHADOW_ATLAS_API_URL if not set
WRITE_RELAY_URL=
# Defaults to SHADOW_ATLAS_REGISTRATION_TOKEN if not set
WRITE_RELAY_TOKEN=

# voter-protocol API URL (Cloudflare Workers deployment — legacy)
# Production: https://reputation.voter.workers.dev
# Development: http://localhost:8787 (wrangler dev)
VOTER_API_URL=https://reputation.voter.workers.dev

# voter-protocol API Authentication
# Generate with: openssl rand -hex 32
VOTER_API_KEY=your-voter-protocol-api-key-here


# ============================================================================
# EMAIL ENRICHMENT (Optional)
# ============================================================================

# Hunter.io API (Email verification and finder)
# Get key from: https://hunter.io/api
# Used for: Email validation and domain search in decision-maker search
HUNTER_IO_API_KEY=your-hunter-io-api-key-here

# Clearbit API (Email enrichment)
# Get key from: https://clearbit.com/
# Used for: Email enrichment with company and profile data
CLEARBIT_API_KEY=your-clearbit-api-key-here


# ============================================================================
# BILLING (Stripe)
# ============================================================================
# Required for org billing: checkout, portal, webhooks, plan enforcement
# Get credentials from: https://dashboard.stripe.com/apikeys

# Stripe API secret key (sk_test_... or sk_live_...)
STRIPE_SECRET_KEY=

# Stripe webhook signing secret (whsec_...)
# Create webhook at: https://dashboard.stripe.com/webhooks
# Events needed: checkout.session.completed, customer.subscription.updated,
#   customer.subscription.deleted, invoice.payment_succeeded, invoice.payment_failed
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs for each plan tier
# Create products+prices at: https://dashboard.stripe.com/products
STRIPE_PRICE_STARTER=
STRIPE_PRICE_ORGANIZATION=
STRIPE_PRICE_COALITION=


# ============================================================================
# SES CLIENT-DIRECT BLAST
# ============================================================================
# Lambda Function URL for the SES proxy (browser calls this directly)
PUBLIC_SES_PROXY_URL=https://your-lambda-function-url.lambda-url.us-east-1.on.aws/
# IAM role ARN for STS AssumeRole — scoped to ses:SendEmail from org's verified address
SES_SEND_ROLE_ARN=arn:aws:iam::123456789012:role/commons-ses-blast-role

# ============================================================================
# SES BOUNCE/COMPLAINT WEBHOOKS
# ============================================================================
# SNS topic ARN that SES publishes bounce/complaint notifications to
# Required for production email deliverability management
SES_SNS_TOPIC_ARN=

# ============================================================================
# BULK EMAIL — PHASE 0.5 LAUNCH GATES
# ============================================================================
# These secrets are REQUIRED before the bulk-email blast path is enforced.
# Without them, the Lambda fails closed (503) per F-125 / F-128 hardening,
# or the SvelteKit-side helpers throw at runtime per F-126 / F-132.
# Generate each as a 32-byte random secret (e.g. `openssl rand -hex 32`).

# F-125 path B: Server-signed dispatch claim binding (orgId, blastId,
# allowedHashes) for the browser→Lambda bulk send. Lambda 503s if unset.
# Mirror the same value to the Lambda's BLAST_DISPATCH_SECRET env var.
BLAST_DISPATCH_SECRET=

# Optional rotation-window previous secret. Dispatch claims have a 30-min
# TTL. SvelteKit signs claims with ONLY the active secret; Lambda accepts
# active OR _PREVIOUS during a rotation window. **Order matters — Lambda
# (receiver) MUST rotate before SvelteKit (sender)**:
#   1. Set BLAST_DISPATCH_SECRET_PREVIOUS = current value on Lambda.
#      Lambda now accepts either old or new claims.
#   2. Set BLAST_DISPATCH_SECRET = new value on Lambda. Lambda now
#      accepts new (active) or old (previous) claims.
#   3. Set BLAST_DISPATCH_SECRET = new value on SvelteKit. SvelteKit
#      starts signing with the new secret; Lambda's _PREVIOUS still
#      accepts any in-flight claims signed with the old.
#   4. Wait > 30 minutes (claim TTL) for in-flight claims to expire.
#   5. Unset BLAST_DISPATCH_SECRET_PREVIOUS on Lambda.
# If you reverse step 1 and step 3 (rotate SvelteKit first), Lambda has
# only the old active and rejects every new claim until step 2 lands.
BLAST_DISPATCH_SECRET_PREVIOUS=

# F-128 Lambda-direct receipt forward: Bearer-auth between Lambda and
# Convex `/webhooks/blast-receipts`. Mirror the same value to the Lambda's
# BLAST_RECEIPTS_SECRET env var, AND set CONVEX_RECEIPTS_URL there too.
BLAST_RECEIPTS_SECRET=

# Optional rotation-window previous secret. Convex accepts
# Bearer tokens matching active OR previous; Lambda always sends with the
# active secret. Rotation procedure (one-way: receiver-first):
#   1. Set BLAST_RECEIPTS_SECRET_PREVIOUS = current value on Convex env
#      (`npx convex env set`). Convex now accepts either.
#   2. Set BLAST_RECEIPTS_SECRET = new value on BOTH Convex and Lambda env.
#      Lambda starts sending under the new secret; Convex still accepts
#      the previous for any in-flight Lambda invocations.
#   3. Wait for in-flight invocations to complete (~minutes).
#   4. Unset BLAST_RECEIPTS_SECRET_PREVIOUS on Convex.
# Constant-time string compare so timing analysis can't distinguish
# wrong-active from wrong-both.
BLAST_RECEIPTS_SECRET_PREVIOUS=

# F-126 / F-132 RFC 8058 List-Unsubscribe per-recipient HMAC token.
# `src/lib/server/email/unsubscribe.ts` throws at runtime if unset, or if
# under-length (32-byte minimum). Use `openssl rand -hex 32`.
UNSUBSCRIBE_SECRET=

# Optional rotation-window previous secret. Unsubscribe links
# may live in inboxes for DAYS — rotation without dual-secret support
# would invalidate every outstanding email link. `verifyUnsubscribeToken`
# tries the active secret first; on mismatch retries against _PREVIOUS.
# Procedure:
#   1. Set _PREVIOUS = current value of UNSUBSCRIBE_SECRET.
#   2. Set UNSUBSCRIBE_SECRET = new value. Deploy.
#   3. Wait long enough for outstanding email links to be opened or be
#      deemed stale (operator judgment — typically 30+ days for marketing
#      email; days for transactional).
#   4. Unset _PREVIOUS. Deploy.
# Same 32-byte minimum applies. Leave unset outside rotation windows.
UNSUBSCRIBE_SECRET_PREVIOUS=

# Server-side org-key seal/unseal for automated send paths
# (`convex/_orgKeyUnseal.ts`). 32-byte hex (64 chars).
# Required when serverSealedOrgKey is in use for any organization;
# `getOrgKeyForAction` returns null without it (and dependent ops fail).
ORG_KEY_WRAPPING_KEY=

# Pseudonymous ID salt for HMAC-SHA256(userId) — breaks the link between
# authenticated identity and on-chain submission rows. THE SAME VALUE
# MUST BE MIRRORED ON THE CONVEX BACKEND (env var `PSEUDONYMOUS_ID_SALT`)
# or the same user will produce two different pseudonymousIds across
# SvelteKit and Convex paths (status checks fail, deliveries mismatch,
# reputation tracking breaks). 32+ character hex (use `openssl rand -hex 32`).
# Legacy name `SUBMISSION_ANONYMIZATION_SALT` still accepted as a fallback.
PSEUDONYMOUS_ID_SALT=

# Session-creation HMAC proof secret. Required by Convex `authOps.createSession`
# (mirror to Convex env `SESSION_CREATION_SECRET`). Without it, OAuth callbacks
# and passkey authentication fail at the Convex side with 503. SvelteKit-side
# OAuth callbacks at `oauth-callback-handler.ts:309` also throw on absence.
# 32+ char hex (use `openssl rand -hex 32`). MUST mirror Convex env exactly.
SESSION_CREATION_SECRET=

# Optional rotation-window previous secret. SvelteKit signs
# session-creation proofs with the active secret; Convex's
# `authOps.createSession` accepts proofs verified by EITHER active OR
# _PREVIOUS so an in-flight session-creation request signed under the
# old secret still verifies during a rotation window. Procedure:
#   1. Set _PREVIOUS = current value on Convex env (`npx convex env set`).
#   2. Set SESSION_CREATION_SECRET = new value on BOTH SvelteKit and
#      Convex env. SvelteKit starts signing with the new secret; Convex
#      still accepts proofs from in-flight SvelteKit auth flows.
#   3. Wait for in-flight session-creation requests to drain (~seconds —
#      session-creation is a single round-trip per auth event).
#   4. Unset _PREVIOUS on Convex.
SESSION_CREATION_SECRET_PREVIOUS=

# Address-resolution HMAC binding token. `/api/location/resolve-address` mints
# a token over (userId, lat, lng, addressHash, expiresAt); `/api/identity/
# verify-address` rejects when the client echoes coordinates without a valid
# matching token. Without this, a malicious client could substitute coordinates
# between geocoding and credential issuance and poison the Tier 2 district
# binding. 32+ char hex (use `openssl rand -hex 32`). SvelteKit-only — Convex
# never sees the token.
ADDRESS_RESOLUTION_TOKEN_SECRET=

# Optional rotation-window previous secret. During key rotation:
#   1. Set _PREVIOUS to the current value of ADDRESS_RESOLUTION_TOKEN_SECRET.
#   2. Set ADDRESS_RESOLUTION_TOKEN_SECRET to the new value. Deploy.
#   3. Wait >= 30 minutes (token TTL) so all in-flight old-secret tokens have
#      expired.
#   4. Unset _PREVIOUS. Deploy.
# verifyAddressResolutionToken tries the active secret first; on mismatch it
# retries against _PREVIOUS so tokens minted just before rotation still verify.
# Same 32-byte minimum applies. Leave unset outside rotation windows.
ADDRESS_RESOLUTION_TOKEN_SECRET_PREVIOUS=

# F-1.1 atlas authenticity gate. Sets the cell-map root and depth pinned
# at deploy time; `verify-commitment.ts` rejects proofs whose cell-map root
# does not match. Optional in dev (warning logged); REQUIRED in production.
EXPECTED_CELL_MAP_ROOT=
EXPECTED_CELL_MAP_DEPTH=

# Comma-separated list of user IDs allowed to invoke admin-only endpoints
# (e.g. `/api/admin/backfill-embeddings`). Empty list = no admin access.
ADMIN_USER_IDS=

# Optional rejection-monitor webhook for proof-rejection alerts.
# REJECTION_THRESHOLD_PERCENT defaults to 1.0 if unset.
REJECTION_MONITOR_WEBHOOK_URL=
REJECTION_THRESHOLD_PERCENT=

# Convex-side internal URL for cross-action callbacks (anchor-on-chain
# request from `submissions.ts:967`, debate-evaluate from `debates.ts:808`).
# Set to the Convex deployment's public URL or a same-tenant SvelteKit URL
# that proxies to the on-chain anchor service. Without it, anchor & debate
# evaluation paths log "COMMONS_INTERNAL_URL not configured" and skip.
COMMONS_INTERNAL_URL=

# TEE Nitro Enclave constituent resolver. When set, Convex submissions
# route district resolution through `${TEE_RESOLVER_URL}/resolve` instead
# of the local SvelteKit resolver. Optional pre-launch (LocalConstituentResolver
# is the active path); REQUIRED post-J-phase per voter-protocol roadmap.
TEE_RESOLVER_URL=

# Bulk-email enclave host (`convex/blasts.ts:146 triggerEnclaveSend`).
# Optional — enclave-sealed bulk send is not the default path; current
# production uses the browser→Lambda flow. Set when J-phase TEE bulk-send
# substrate ships.
ENCLAVE_PARENT_HOST=

# Convex-side feature & launch flags.
# FEATURE_CONGRESSIONAL: when "true", enables the CWC delivery path.
# CONGRESSIONAL_DELIVERY_LAUNCHED: when "true", removes the pre-launch guard
# that throws DELIVERY_NOT_LAUNCHED on submission. Both default off.
FEATURE_CONGRESSIONAL=
CONGRESSIONAL_DELIVERY_LAUNCHED=

# Convex deployment self-URL (used for SES bounce webhook callbacks etc.).
# Convex sets this automatically in cloud deployments; only set explicitly
# for self-hosted Convex.
CONVEX_SITE_URL=


# ============================================================================
# TRUSTED EXECUTION ENVIRONMENT (TEE) - Optional
# ============================================================================
# TEE configuration for privacy-preserving computation
# Current target: AWS Nitro Enclaves (mock/Phase 2)
# Azure support is planned but not yet implemented

# ──────────────────────────────────────────────────────────────────────────
# AWS Nitro Enclaves Configuration
# ──────────────────────────────────────────────────────────────────────────
# Required for AWS Nitro TEE deployment
# Get credentials from: https://console.aws.amazon.com/iam/

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_ACCOUNT_ID=123456789012

# Nitro Enclave Instance Configuration
AWS_NITRO_INSTANCE_TYPE=c6a.xlarge
AWS_VPC_ID=vpc-xxxxx
AWS_SUBNET_ID=subnet-xxxxx
AWS_SECURITY_GROUP_IDS=sg-xxxxx,sg-yyyyy
AWS_IAM_INSTANCE_PROFILE=commons-nitro-role
AWS_ENCLAVE_BUCKET=commons-nitro-enclaves

# ──────────────────────────────────────────────────────────────────────────
# Azure Confidential Computing (Not yet implemented)
# ──────────────────────────────────────────────────────────────────────────
# Placeholder for future Azure TEE support
# AZURE_SUBSCRIPTION_ID=your-subscription-id
# AZURE_RESOURCE_GROUP=your-resource-group
# AZURE_REGION=eastus


# ============================================================================
# PUBLIC ENVIRONMENT VARIABLES (Client-side)
# ============================================================================

# ============================================================================
# BLOCKCHAIN INFRASTRUCTURE (Scroll L2) — Wave 15b
# ============================================================================

# Scroll RPC URL (public, used for client-side read queries)
PUBLIC_SCROLL_RPC_URL=https://rpc.scroll.io

# Scroll RPC URL (private, used for server-side relayer transactions)
# Use a dedicated RPC endpoint for reliability (Alchemy, Infura, or self-hosted)
# TESTNET: https://sepolia-rpc.scroll.io
# MAINNET: https://rpc.scroll.io (or Alchemy/Infura endpoint)
SCROLL_RPC_URL=https://sepolia-rpc.scroll.io

# DistrictGate contract address (deployed on Scroll)
# V11 Scroll Sepolia (hardened, parameterized 10-min timelocks)
DISTRICT_GATE_ADDRESS=0x139F96f38931cF2C2E1B4D285028d748F9DCA157

# On-chain root registries (Scroll Sepolia V11)
USER_ROOT_REGISTRY_ADDRESS=0x8213566D3232185Fe7457133DF6cf0596c2c98E9
CELL_MAP_REGISTRY_ADDRESS=0x4Cd43f0c9C288EF587da261A400EF88cE158865A
VERIFIER_REGISTRY_ADDRESS=0xbfb2217A77223AEFCAa7fE45848e05FFFeD285EA
NULLIFIER_REGISTRY_ADDRESS=0x99C190e3c9d2124304f86A15EB8E3c717e2710c9
CAMPAIGN_REGISTRY_ADDRESS=0x9533A9dad1A20b43bd490e81C84b3d08Ab89fdB8
DISTRICT_REGISTRY_ADDRESS=0x9AF734Ac0010Cb1a1A785Df087F7A45b70A79C0E

# Engagement Root Registry (Three-Tree Architecture)
ENGAGEMENT_ROOT_REGISTRY_ADDRESS=0x8fe7F5a7972484381E1c3e2d4503317cbd96d4D0

# DebateMarket (staked deliberation protocol)
DEBATE_MARKET_ADDRESS=0xA07D6F620FEc31A163E1F888956e4c98D522B906

# ERC-20 staking token (USDC on Scroll — 6 decimals)
# V8: USDC staking replaces native ETH. Protocol takes 2% fee on argument stakes.
PUBLIC_STAKING_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000

# Wallet — Fiat Onramp (Transak)
# Required for the OnrampWidget fiat-to-USDC purchase flow
# PUBLIC_TRANSAK_API_KEY=your-transak-api-key

# ZK Circuit depth (default: 20). Controls Merkle tree capacity (2^depth leaves).
# Valid values: 18, 20, 22, 24. Depth 20 covers all US states.
# Override for international expansion (larger trees need higher depth).
# This is a VITE_ var — exposed to browser-side prover-client.ts.
VITE_CIRCUIT_DEPTH=20

# Server relayer wallet private key (pays gas for on-chain verification)
# This wallet MUST be funded with ETH on Scroll for gas.
# Generate: cast wallet new | grep "Private key"
# Fund: bridge ETH to Scroll via bridge.scroll.io
# CRITICAL: Never commit this value. Use secrets manager in production.
SCROLL_PRIVATE_KEY=


# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Beta features (default: false)
# Controls access to features in FeatureStatus.BETA
# Note: Only PUBLIC_ENABLE_BETA is actually used in the codebase
PUBLIC_ENABLE_BETA=false

# Smart Account (EIP-7702 delegation, default: false)
# When true: Wraps EVMWalletProvider with SmartAccountProvider for 7702 delegation
# When false: Standard EOA-only mode (no delegation)
# Requires: ethers v6 + MetaMask 7702 support + Scroll Euclid upgrade
PUBLIC_ENABLE_SMART_ACCOUNTS=false

# Pimlico API Key (Optional, for future paymaster/gas sponsorship)
# Get key from: https://dashboard.pimlico.io
# Not used in current implementation — 7702 delegation only
# PIMLICO_API_KEY=

# Analytics Configuration
# USE_SNAPSHOT_ONLY (default: true)
# When true: Queries use pre-noised snapshots (differential privacy enforced)
# When false: Queries can access raw aggregates (PRIVACY LEAK RISK)
# Production should ALWAYS be true
USE_SNAPSHOT_ONLY=true

# Differential Privacy (default: false)
# When true: Full two-layer DP — client LDP (k-ary RR) + server noise (Laplace snapshots)
# When false: Raw metrics, no noise — accurate counts for low-traffic product analysis
# Flip to true when DAU > ~100 (noise becomes statistically meaningful)
ANALYTICS_DP_ENABLED=false

# Rate Limiting Backend
# RATE_LIMIT_USE_DB (default: false)
# When true: Uses database for distributed rate limiting
# When false: Uses in-memory rate limiting (single instance only)
RATE_LIMIT_USE_DB=false

# Rate Limiting
# Production must set REDIS_URL, or explicitly opt into per-isolate memory
# with RATE_LIMITER_ALLOW_MEMORY=1 for low-traffic smoke/release windows.
# REDIS_URL=redis://localhost:6379
RATE_LIMITER_ALLOW_MEMORY=0

# Agent Trace Persistence (default: false)
# When true: Pipeline events (inputs, prompts, responses, source URLs, LLM
# thinking, errors) are persisted to Convex `agentTraces` table for operator
# replay/debug. Replaces the no-op stub that previously made the surface
# look wired without persisting anything.
# When false: writer is a no-op; pipeline runs identically with zero
# observability cost. Console.log lines for the same events remain.
#
# Privacy: TTL + `_secret` gate are the privacy primitives. The writer
# scrubs auth headers / OAuth tokens / API keys (key-based + string-content
# regex for Bearer/AWS-SigV4/AKIA/Stripe/GitHub/Google/Groq/JWT). User
# content (prompts, message bodies) is captured verbatim — replay requires
# fidelity.
#
# Operator commands documented in:
#   src/lib/server/agent-trace.ts header
#   memory/agent_trace_writer.md
AGENT_TRACE_ENABLED=false
AGENT_TRACE_TTL_DAYS=7
AGENT_TRACE_SAMPLE_RATE=1.0


# ============================================================================
# INTELLIGENCE LOOP
# ============================================================================

# Open States API Key (Required for state-level bill ingestion)
# Get key from: https://openstates.org/accounts/signup/
# Free tier: 1,000 requests/day
OPEN_STATES_API_KEY=

# Congress.gov API key is listed above under CONGRESSIONAL INTEGRATION


# ============================================================================
# ERROR MONITORING (Sentry)
# ============================================================================
# Server-side DSN (private, never exposed to client)
SENTRY_DSN=
# Client-side DSN (public, embedded in browser bundle via Vite)
VITE_SENTRY_DSN=
# Environment label sent to Sentry (production, staging, development)
ENVIRONMENT=development
VITE_ENVIRONMENT=development

MDL_OPENID4VP_REQUEST_PRIVATE_KEY=
MDL_OPENID4VP_REQUEST_X5C=
MDL_OPENID4VP_REQUEST_ALG=ES256
MDL_OPENID4VP_REQUEST_KID=
MDL_OPENID4VP_REQUEST_AUD=


# ============================================================================
# DEVELOPMENT SETTINGS
# ============================================================================

# Node Environment
NODE_ENV=development

# Server Configuration (SvelteKit defaults)
PORT=5173
HOST=localhost

# Logging Level (debug | info | warn | error)
LOG_LEVEL=info

# ============================================================================
# CONVEX
# ============================================================================
# Convex deployment URL (from `npx convex dev` or Convex dashboard)
PUBLIC_CONVEX_URL="https://your-project.convex.cloud"

# Convex Auth Bridge — RSA key pair for JWT signing (RS256)
# Generate with: node scripts/generate-convex-jwk.mjs
# The private key signs JWTs in SvelteKit; the public key is served
# via /.well-known/jwks.json for Convex to verify.
CONVEX_JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# CONVEX_AUTH_ISSUER and CONVEX_JWT_KID are documented in the Federation
# parameters section near the top of this file. Both must be set in BOTH the
# SvelteKit .env (this file) AND the Convex dashboard.
